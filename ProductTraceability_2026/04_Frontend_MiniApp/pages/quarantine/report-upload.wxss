/* ============================================================
   报告上传 - 采集页 + 全屏Loading + 数字证书存证确认页
   ============================================================ */

/* ========== 全屏 Loading ========== */
.fullscreen-loading {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255, 255, 255, 0.97);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-shield {
  width: 120rpx;
  height: 120rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  border: 4rpx solid #4CAF50;
  animation: pulse 1.5s ease-in-out infinite;
}

.shield-icon {
  width: 64rpx;
  height: 64rpx;
}

.loading-spinner-ring {
  width: 160rpx;
  height: 160rpx;
  border: 6rpx solid #E8F5E9;
  border-top: 6rpx solid #4CAF50;
  border-right: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
  position: absolute;
}

@keyframes spin { to { transform: rotate(360deg); } }
@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.08); }
}

.loading-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-top: 40rpx;
  margin-bottom: 8rpx;
}

.loading-subtitle {
  font-size: 26rpx;
  color: #4CAF50;
  margin-bottom: 32rpx;
}

.loading-dots { display: flex; gap: 16rpx; }

.dot {
  width: 16rpx; height: 16rpx; border-radius: 50%;
  background: #4CAF50;
  animation: bounce 1.2s ease-in-out infinite;
}
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 存证确认页 ========== */
.cert-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 35%);
  padding: 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 顶部盾牌 */
.cert-top {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 24rpx;
}

.cert-shield-wrap {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  margin-bottom: 20rpx;
}

.cert-shield {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 40rpx rgba(46, 125, 50, 0.35);
  position: relative;
  z-index: 2;
}

.cert-shield-check {
  font-size: 64rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.cert-shield-ring {
  position: absolute;
  top: -10rpx; left: -10rpx;
  width: 160rpx; height: 160rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(76, 175, 80, 0.3);
  z-index: 1;
}

.cert-top-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 6rpx;
}

.cert-top-sub {
  font-size: 26rpx;
  color: #81C784;
}

/* 证书卡片 */
.cert-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 16rpx;
  padding: 32rpx 24rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #E8F5E9;
}

.cert-card-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
}

.cert-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent, #C8E6C9, transparent);
}

.cert-card-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E7D32;
  padding: 0 20rpx;
  white-space: nowrap;
}

/* 缩略图 */
.cert-thumbs {
  display: flex;
  justify-content: center;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.cert-thumb {
  width: 180rpx;
  height: 130rpx;
  border-radius: 12rpx;
  border: 2rpx solid #E0E0E0;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

/* 证书信息 */
.cert-info-area {
  margin-bottom: 20rpx;
}

.cert-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #FAFAFA;
}

.cert-row:last-child { border-bottom: none; }

.cert-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.cert-val {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cert-mono {
  font-family: 'Courier New', monospace;
  color: #2E7D32;
}

/* 区块链凭据区 */
.cert-chain-area {
  background: #F8FBF8;
  border-radius: 14rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
  border: 1rpx solid #E8F5E9;
}

.cert-chain-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  gap: 10rpx;
}

.cert-chain-icon {
  width: 32rpx;
  height: 32rpx;
}

.cert-chain-label {
  font-size: 26rpx;
  font-weight: 600;
  color: #2E7D32;
}

.cert-hash-item {
  padding: 14rpx 0;
  border-bottom: 1rpx solid #E8F5E9;
}

.cert-hash-item:last-of-type { border-bottom: none; }

.cert-hash-key {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.cert-hash-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.cert-hash-val {
  font-size: 24rpx;
  color: #333;
  font-family: 'SF Mono', 'Courier New', monospace;
  flex: 1;
}

.cert-copy-tag {
  display: flex;
  align-items: center;
  gap: 6rpx;
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 8rpx 16rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.cert-copy-tag:active { background: #C8E6C9; }

.cert-copy-img { width: 24rpx; height: 24rpx; }

.cert-copy-text { font-size: 22rpx; color: #2E7D32; }

.cert-meta-grid {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.cert-meta-box {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid #E8F5E9;
}

.cert-meta-key { font-size: 22rpx; color: #999; margin-bottom: 6rpx; }
.cert-meta-val { font-size: 24rpx; color: #333; font-weight: 500; font-family: 'Courier New', monospace; }

/* 底部声明 */
.cert-seal {
  text-align: center;
  padding-top: 16rpx;
}

.cert-seal-text {
  font-size: 20rpx;
  color: #BDBDBD;
}

/* 操作按钮 */
.cert-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 36rpx;
}

.cert-btn-outline {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  background: #FFFFFF;
  border: 2rpx solid #E0E0E0;
  border-radius: 44rpx;
  font-size: 30rpx; color: #666; font-weight: 500;
}

.cert-btn-outline:active { background: #F5F5F5; }

.cert-btn-solid {
  flex: 1; height: 88rpx;
  display: flex; align-items: center; justify-content: center;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 44rpx;
  font-size: 30rpx; color: #FFFFFF; font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(46, 125, 50, 0.3);
}

.cert-btn-solid:active { opacity: 0.85; }

/* ========== 采集页 ========== */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.section-card {
  background: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 标题行 */
.section-title-row {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.step-badge {
  width: 44rpx; height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50, #2E7D32);
  color: #FFFFFF;
  font-size: 24rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
  margin-right: 12rpx; flex-shrink: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  flex: 1;
}

.unlink-tag {
  padding: 6rpx 16rpx;
  border-radius: 16rpx;
  background: #FFF3E0;
  border: 1rpx solid #FFE0B2;
  font-size: 22rpx; color: #E65100;
}

.img-count {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

/* 已关联 */
.linked-bar {
  display: flex;
  align-items: center;
  background: #E8F5E9;
  border: 1rpx solid #C8E6C9;
  border-radius: 10rpx;
  padding: 12rpx 16rpx;
  margin-bottom: 16rpx;
}

.linked-check {
  width: 36rpx; height: 36rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #FFF; font-size: 22rpx; font-weight: bold;
  display: flex; align-items: center; justify-content: center;
  margin-right: 10rpx; line-height: 36rpx; text-align: center;
}

.linked-txt { font-size: 26rpx; color: #2E7D32; font-weight: 500; }

.batch-info-grid { }

.bi-row {
  display: flex;
  justify-content: space-between;
  padding: 10rpx 0;
}

.bi-label { font-size: 26rpx; color: #999; }
.bi-val { font-size: 26rpx; color: #333; font-weight: 500; }
.bi-mono { font-family: 'Courier New', monospace; color: #2E7D32; }

/* 扫码按钮 */
.scan-btn-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
}

.scan-btn-area:active { opacity: 0.85; }

.scan-btn-icon { width: 100rpx; height: 100rpx; margin-bottom: 16rpx; }

.scan-btn-text { font-size: 30rpx; color: #2E7D32; font-weight: bold; margin-bottom: 6rpx; }
.scan-btn-hint { font-size: 24rpx; color: #81C784; }

/* 或分隔 */
.or-divider { display: flex; align-items: center; margin: 20rpx 0; }
.or-line { flex: 1; height: 1rpx; background: #E0E0E0; }
.or-text { font-size: 24rpx; color: #999; padding: 0 16rpx; }

/* 手动输入 */
.manual-row { display: flex; gap: 12rpx; align-items: center; }

.manual-input {
  flex: 1; background: #F5F5F5; border-radius: 8rpx;
  padding: 18rpx 20rpx; font-size: 28rpx; color: #333;
  border: 1rpx solid #EEE;
}

.manual-btn {
  width: 120rpx; height: 76rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFF; font-size: 28rpx; font-weight: bold;
  border-radius: 8rpx;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0;
}

.manual-btn:active { opacity: 0.85; }

/* ========== 照片网格 ========== */
.img-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.img-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #EEEEEE;
}

.img-preview {
  width: 100%;
  height: 100%;
}

.img-delete {
  position: absolute;
  top: 0; right: 0;
  width: 48rpx; height: 48rpx;
  background: rgba(0, 0, 0, 0.55);
  color: #FFF;
  font-size: 32rpx;
  display: flex; align-items: center; justify-content: center;
  border-bottom-left-radius: 12rpx;
}

.img-add {
  width: 200rpx; height: 200rpx;
  border: 2rpx dashed #BDBDBD;
  border-radius: 12rpx;
  display: flex; flex-direction: column;
  align-items: center; justify-content: center;
  background: #FAFAFA;
}

.img-add:active { background: #F0F0F0; }

.img-add-icon {
  font-size: 56rpx;
  color: #BDBDBD;
  line-height: 1;
  margin-bottom: 8rpx;
}

.img-add-text {
  font-size: 22rpx;
  color: #999;
}

.img-hint {
  font-size: 22rpx;
  color: #BDBDBD;
}

/* ========== 表单 ========== */
.form-item { margin-bottom: 24rpx; }
.form-item:last-child { margin-bottom: 0; }

.form-label {
  display: block; font-size: 26rpx; color: #666;
  margin-bottom: 12rpx; font-weight: 500;
}

.required-label::before {
  content: '*'; color: #E65100; margin-right: 4rpx;
}

.form-input {
  background: #F8F8F8; border-radius: 12rpx;
  padding: 20rpx 24rpx; font-size: 28rpx; color: #333;
  border: 1rpx solid #EEE;
}

.form-textarea {
  background: #F8F8F8; border-radius: 12rpx;
  padding: 20rpx 24rpx; font-size: 28rpx; color: #333;
  width: 100%; min-height: 100rpx;
  border: 1rpx solid #EEE; box-sizing: border-box;
}

/* ========== 提交 ========== */
.submit-area {
  padding: 16rpx 30rpx 30rpx;
}

.chain-notice {
  display: flex; align-items: flex-start;
  background: #FFFFFF; border: 1rpx solid #E0E0E0;
  border-radius: 12rpx; padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.notice-icon { font-size: 28rpx; margin-right: 10rpx; flex-shrink: 0; line-height: 1.6; }
.notice-text { font-size: 24rpx; color: #999999; line-height: 1.6; }

.submit-btn {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  color: #FFFFFF; text-align: center;
  padding: 26rpx 0; border-radius: 44rpx;
  font-size: 32rpx; font-weight: 600;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.35);
  display: flex; align-items: center; justify-content: center; gap: 12rpx;
}

.submit-btn:active { opacity: 0.85; }

.submit-icon { width: 36rpx; height: 36rpx; }

.submit-disabled {
  background: #BDBDBD;
  box-shadow: none;
}

/* 自动填充字段 */
.autofill-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F0F7F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #C8E6C9;
}

.autofill-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  font-family: 'Courier New', monospace;
}

.autofill-tag {
  font-size: 20rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #C8E6C9;
}

/* 区块链存证信息区 */
.cert-blockchain-section {
  background: #F8FBF8;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-top: 20rpx;
  border: 1rpx solid #E8F5E9;
}

.cert-blockchain-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2E7D32;
  margin-bottom: 16rpx;
}

.cert-param-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #E8F5E9;
}

.cert-param-row:last-of-type {
  border-bottom: none;
}

.cert-param-label {
  font-size: 24rpx;
  color: #666;
}

.cert-param-value {
  font-size: 24rpx;
  color: #1976D2;
  font-family: 'Courier New', monospace;
}

.cert-param-meta {
  display: flex;
  justify-content: space-between;
  margin-top: 12rpx;
  padding-top: 12rpx;
  border-top: 1rpx solid #E8F5E9;
}

.cert-param-meta-item {
  flex: 1;
  text-align: center;
}

.cert-param-meta-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.cert-param-meta-value {
  display: block;
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
}
