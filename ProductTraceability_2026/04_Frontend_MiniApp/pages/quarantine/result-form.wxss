/* ============================================================
   检疫录入页 - 含全屏 Loading、证书展示、表单三态
   ============================================================ */

/* ========== 全屏 Loading ========== */
.fullscreen-loading {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(255, 255, 255, 0.96);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.loading-spinner-large {
  width: 100rpx;
  height: 100rpx;
  border: 6rpx solid #E8F5E9;
  border-top: 6rpx solid #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 24rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-chain-icon {
  margin-bottom: 32rpx;
}

.chain-anim-icon {
  width: 80rpx;
  height: 80rpx;
  animation: pulse 1.5s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% { transform: scale(1); opacity: 0.8; }
  50% { transform: scale(1.15); opacity: 1; }
}

.loading-title {
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 12rpx;
}

.loading-subtitle {
  font-size: 28rpx;
  color: #4CAF50;
  margin-bottom: 32rpx;
}

.loading-dots {
  display: flex;
  gap: 16rpx;
}

.dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: #4CAF50;
  animation: bounce 1.2s ease-in-out infinite;
}
.dot1 { animation-delay: 0s; }
.dot2 { animation-delay: 0.2s; }
.dot3 { animation-delay: 0.4s; }

@keyframes bounce {
  0%, 80%, 100% { transform: scale(0.6); opacity: 0.4; }
  40% { transform: scale(1); opacity: 1; }
}

/* ========== 存证成功 - 证书页 ========== */
.success-container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 40%);
  padding: 40rpx 30rpx;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.success-header {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 0 30rpx;
}

.success-icon-wrap {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(76, 175, 80, 0.35);
}

.success-check {
  font-size: 60rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.success-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.success-subtitle {
  font-size: 26rpx;
  color: #81C784;
}

/* ========== 电子检疫证书卡片 ========== */
.certificate-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  margin-top: 20rpx;
  padding: 36rpx 28rpx;
  box-shadow: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  border: 2rpx solid #E8F5E9;
}

.cert-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
}

.cert-header-line {
  flex: 1;
  height: 2rpx;
  background: linear-gradient(90deg, transparent 0%, #C8E6C9 50%, transparent 100%);
}

.cert-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #2E7D32;
  padding: 0 20rpx;
  white-space: nowrap;
}

/* 检疫结果徽章 */
.cert-result-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  gap: 16rpx;
}

.cert-result-label {
  font-size: 28rpx;
  color: #666;
}

.cert-result-badge {
  padding: 12rpx 40rpx;
  border-radius: 30rpx;
  font-weight: bold;
}

.cert-pass {
  background: #E8F5E9;
  border: 2rpx solid #4CAF50;
}

.cert-pass .cert-result-text {
  color: #2E7D32;
  font-size: 32rpx;
}

.cert-fail {
  background: #FFEBEE;
  border: 2rpx solid #EF5350;
}

.cert-fail .cert-result-text {
  color: #C62828;
  font-size: 32rpx;
}

/* 证书信息区 */
.cert-info-section {
  margin-bottom: 24rpx;
}

.cert-info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14rpx 0;
  border-bottom: 1rpx solid #FAFAFA;
}

.cert-info-row:last-child {
  border-bottom: none;
}

.cert-info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.cert-info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  max-width: 60%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.cert-mono {
  font-family: 'Courier New', monospace;
  color: #2E7D32;
}

/* 分隔线 */
.cert-divider {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
}

.cert-divider-line {
  flex: 1;
  height: 1rpx;
  background: #E0E0E0;
}

.cert-divider-icon {
  width: 40rpx;
  height: 40rpx;
  margin: 0 16rpx;
}

/* 区块链存证信息区 */
.cert-chain-section {
  background: #F8FBF8;
  border-radius: 12rpx;
  padding: 24rpx 20rpx;
  margin-bottom: 20rpx;
}

.cert-chain-pending {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
}

.cert-pending-notice {
  padding: 20rpx 16rpx;
  text-align: center;
}

.cert-pending-text {
  font-size: 26rpx;
  color: #999999;
  line-height: 1.6;
}

.cert-chain-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #2E7D32;
  margin-bottom: 20rpx;
}

.cert-hash-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #E8F5E9;
}

.cert-hash-row:last-of-type {
  border-bottom: none;
}

.cert-hash-left {
  flex: 1;
  min-width: 0;
}

.cert-hash-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.cert-hash-value {
  display: block;
  font-size: 24rpx;
  color: #333;
  font-family: 'SF Mono', 'Courier New', monospace;
  word-break: break-all;
}

.cert-copy-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #E8F5E9;
  border-radius: 12rpx;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.cert-copy-btn:active {
  background: #C8E6C9;
}

.cert-copy-icon {
  width: 32rpx;
  height: 32rpx;
}

.cert-meta-row {
  display: flex;
  margin-top: 16rpx;
  gap: 20rpx;
}

.cert-meta-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  background: #FFFFFF;
  border-radius: 10rpx;
  padding: 16rpx 12rpx;
  border: 1rpx solid #E8F5E9;
}

.cert-meta-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.cert-meta-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  font-family: 'Courier New', monospace;
}

/* 证书底部 */
.cert-footer {
  text-align: center;
  padding-top: 16rpx;
}

.cert-footer-text {
  font-size: 20rpx;
  color: #BDBDBD;
  line-height: 1.6;
}

/* 操作按钮 */
.success-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
  padding: 0 10rpx;
}

.action-btn-secondary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border: 2rpx solid #E0E0E0;
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #666;
  font-weight: 500;
}

.action-btn-secondary:active {
  background: #F5F5F5;
}

.action-btn-primary {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 44rpx;
  font-size: 30rpx;
  color: #FFFFFF;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.3);
}

.action-btn-primary:active {
  opacity: 0.85;
}

/* ========== 正常表单页 ========== */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

.info-card, .form-card {
  background: #FFFFFF;
  margin: 20rpx 30rpx;
  border-radius: 16rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

/* 标题行 */
.card-title-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 0;
}

.form-card .card-title {
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.unlink-btn {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  background: #FFF3E0;
  border: 1rpx solid #FFE0B2;
}

.unlink-text {
  font-size: 22rpx;
  color: #E65100;
  font-weight: 500;
}

/* 已关联标识 */
.linked-badge {
  display: flex;
  align-items: center;
  background: #E8F5E9;
  border: 1rpx solid #C8E6C9;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 20rpx;
}

.linked-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 24rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  flex-shrink: 0;
  text-align: center;
  line-height: 40rpx;
}

.linked-text {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 500;
}

/* 关联信息 */
.info-row {
  display: flex;
  justify-content: space-between;
  padding: 12rpx 0;
}

.info-label {
  font-size: 26rpx;
  color: #999;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.batch-code-value {
  color: #2E7D32;
  font-family: 'Courier New', monospace;
}

/* 扫码区域 */
.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 50rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 16rpx;
  margin-bottom: 24rpx;
}

.scan-area:active {
  opacity: 0.85;
}

.scan-icon-large {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 20rpx;
}

.scan-tip {
  font-size: 30rpx;
  color: #2E7D32;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.scan-sub-tip {
  font-size: 24rpx;
  color: #81C784;
}

/* 分隔线 */
.divider-row {
  display: flex;
  align-items: center;
  margin: 24rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E0E0E0;
}

.divider-text {
  font-size: 24rpx;
  color: #999;
  padding: 0 20rpx;
}

/* 手动输入 */
.manual-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.batch-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #EEEEEE;
}

.confirm-btn-small {
  width: 140rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.confirm-btn-small:active {
  opacity: 0.85;
}

/* 表单禁用态 */
.form-disabled {
  position: relative;
  opacity: 0.55;
  pointer-events: none;
}

.disabled-overlay {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FAFAFA;
  border: 1rpx dashed #BDBDBD;
  border-radius: 12rpx;
  padding: 28rpx 20rpx;
  margin-bottom: 24rpx;
}

.disabled-text {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
}

.form-label {
  display: block;
  font-size: 26rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required-label::before {
  content: '*';
  color: #E65100;
  margin-right: 4rpx;
}

.form-input {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #EEEEEE;
}

.picker-input {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.picker-arrow {
  font-size: 32rpx;
  color: #CCC;
}

.form-textarea {
  background: #F8F8F8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  min-height: 140rpx;
  border: 1rpx solid #EEEEEE;
  box-sizing: border-box;
}

/* 检疫结果单选 */
.result-switch {
  display: flex;
  gap: 20rpx;
}

.result-option {
  flex: 1;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 30rpx;
  color: #666;
  background: #F8F8F8;
  border: 2rpx solid #EEEEEE;
  font-weight: 500;
}

.result-active-pass {
  background: #E8F5E9;
  color: #2E7D32;
  border-color: #4CAF50;
}

.result-active-fail {
  background: #FFEBEE;
  color: #C62828;
  border-color: #EF5350;
}

/* 自动填充字段 */
.autofill-field {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: #F0F7F0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  border: 1rpx solid #C8E6C9;
}

.autofill-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  font-family: 'Courier New', monospace;
}

.autofill-tag {
  font-size: 20rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #C8E6C9;
}

.autofill-hint {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
  padding-left: 4rpx;
}

/* 存证提示 + 提交 */
.submit-section {
  padding: 20rpx 30rpx 30rpx;
}

.chain-notice {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 24rpx;
}

.chain-notice-icon {
  font-size: 28rpx;
  margin-right: 10rpx;
  flex-shrink: 0;
  line-height: 1.6;
}

.chain-notice-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
}

.submit-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #FFFFFF;
  text-align: center;
  padding: 26rpx 0;
  border-radius: 44rpx;
  font-size: 32rpx;
  font-weight: 600;
  box-shadow: 0 6rpx 20rpx rgba(76, 175, 80, 0.3);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
}

.submit-btn:active {
  opacity: 0.85;
}

.submit-chain-icon {
  width: 36rpx;
  height: 36rpx;
}

.submit-btn-disabled {
  background: #BDBDBD;
  box-shadow: none;
}
