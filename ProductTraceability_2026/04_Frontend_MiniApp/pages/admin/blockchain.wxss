/* 区块链管理页面样式 - 与项目整体风格保持一致 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 页面头部 */
.page-header {
  background: #4CAF50;
  padding: 40rpx 30rpx 80rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* 区域通用样式 */
.section {
  margin: 0 24rpx 24rpx;
}

.section:first-of-type {
  margin-top: -50rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
  padding: 0 8rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  position: relative;
  padding-left: 20rpx;
}

.section-title::before {
  content: '';
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 28rpx;
  background: linear-gradient(180deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 3rpx;
}

/* 刷新按钮 */
.refresh-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #FFFFFF;
  border-radius: 50%;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.refresh-icon {
  font-size: 32rpx;
  color: #4CAF50;
  transition: transform 0.3s;
}

.refresh-icon.rotating {
  animation: rotate 1s linear infinite;
}

@keyframes rotate {
  from { transform: rotate(0deg); }
  to { transform: rotate(360deg); }
}

/* ========== 节点监控卡片 ========== */
.node-status-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.status-header {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.status-indicator {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 12rpx;
}

.status-indicator.online {
  background: #4CAF50;
  box-shadow: 0 0 12rpx rgba(76, 175, 80, 0.5);
}

.status-indicator.offline {
  background: #F44336;
  box-shadow: 0 0 12rpx rgba(244, 67, 54, 0.5);
}

.status-text {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-right: 16rpx;
}

.network-name {
  font-size: 22rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
}

.node-info-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.node-info-item {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx;
}

.info-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.info-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.info-value.mono {
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  word-break: break-all;
}

.info-value.highlight {
  color: #4CAF50;
  font-weight: 600;
}

/* ========== 数据统计网格 ========== */
.stats-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
}

.stats-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.stats-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.tx-icon {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
}

.hash-icon {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
}

.batch-icon {
  background: linear-gradient(135deg, #81C784 0%, #66BB6A 100%);
}

.enterprise-icon {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
}

.stats-info {
  flex: 1;
  min-width: 0;
}

.stats-value {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}

/* ========== Gas 费用监控 ========== */
.gas-monitor-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.gas-main {
  background: linear-gradient(135deg, #1B5E20 0%, #2E7D32 100%);
  padding: 32rpx;
  text-align: center;
}

.gas-total {
  display: flex;
  align-items: baseline;
  justify-content: center;
  margin-bottom: 8rpx;
}

.gas-value {
  font-size: 56rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.gas-unit {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-left: 8rpx;
}

.gas-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.gas-details {
  padding: 20rpx;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
}

.gas-item {
  background: #FAFAFA;
  border-radius: 8rpx;
  padding: 16rpx;
}

.gas-item-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.gas-item-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

/* ========== 智能合约公示 ========== */
.contract-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.contract-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 20rpx;
}

.contract-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.contract-badge {
  font-size: 20rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

.contract-address-section {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.address-label {
  display: block;
  font-size: 22rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.address-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.address-value {
  font-size: 24rpx;
  color: #1B5E20;
  font-family: 'Courier New', monospace;
  flex: 1;
  word-break: break-all;
  margin-right: 16rpx;
}

.copy-btn {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.copy-icon {
  width: 44rpx;
  height: 44rpx;
  opacity: 0.7;
}

.contract-info-list {
  display: flex;
  justify-content: space-between;
  margin-bottom: 20rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.contract-info-item {
  text-align: center;
}

.item-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.item-value {
  display: block;
  font-size: 24rpx;
  color: #333;
}

.item-value.status-active {
  color: #4CAF50;
}

.contract-functions {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx;
}

.functions-title {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.function-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.function-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.function-name {
  font-size: 24rpx;
  color: #4CAF50;
  font-family: 'Courier New', monospace;
}

.function-desc {
  font-size: 22rpx;
  color: #999;
}

/* ========== 技术架构说明 ========== */
.tech-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 20rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.08);
}

.tech-item {
  display: flex;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.tech-item:last-child {
  border-bottom: none;
}

.tech-tag {
  font-size: 22rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  font-weight: 500;
}

.tech-value {
  font-size: 24rpx;
  color: #666;
  flex: 1;
}

/* ========== 底部说明 ========== */
.footer-note {
  text-align: center;
  padding: 24rpx 30rpx;
}

.footer-note text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.6;
}
