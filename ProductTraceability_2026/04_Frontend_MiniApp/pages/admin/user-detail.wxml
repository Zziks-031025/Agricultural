<view class="detail-container">
  <!-- 用户头部信息 -->
  <view class="user-header">
    <view class="header-content">
      <view class="avatar-wrapper">
        <image class="avatar" src="{{userInfo.avatar || 'https://via.placeholder.com/120/4CAF50/FFFFFF?text=U'}}" mode="aspectFill"></image>
        <view class="status-dot {{userInfo.status === 1 ? 'active' : 'frozen'}}"></view>
      </view>
      <view class="user-main-info">
        <view class="user-name">{{userInfo.realName || userInfo.username}}</view>
        <view class="user-username">@{{userInfo.username}}</view>
      </view>
      <view class="status-tag {{userInfo.status === 1 ? 'active' : 'frozen'}}">
        {{userInfo.status === 1 ? '正常' : '已冻结'}}
      </view>
    </view>
  </view>

  <!-- 账号信息 -->
  <view class="info-section">
    <view class="section-title">账号信息</view>
    <view class="info-row">
      <text class="info-label">用户ID</text>
      <text class="info-value">{{userInfo.id}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">用户名</text>
      <text class="info-value">{{userInfo.username}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">用户类型</text>
      <text class="info-value">{{userInfo.userType === 1 ? '管理员' : userInfo.userType === 2 ? '企业用户' : '普通用户'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">账号状态</text>
      <text class="info-value {{userInfo.status === 1 ? 'text-success' : 'text-danger'}}">{{userInfo.status === 1 ? '正常' : '已冻结'}}</text>
    </view>
  </view>

  <!-- 联系信息 -->
  <view class="info-section">
    <view class="section-title">联系信息</view>
    <view class="info-row">
      <text class="info-label">手机号码</text>
      <text class="info-value {{userInfo.phone ? 'clickable' : ''}}" bindtap="callPhone" data-phone="{{userInfo.phone}}">{{userInfo.phone || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">邮箱地址</text>
      <text class="info-value">{{userInfo.email || '-'}}</text>
    </view>
  </view>

  <!-- 企业信息（企业用户才显示） -->
  <view class="info-section" wx:if="{{userInfo.userType === 2}}">
    <view class="section-title">企业信息</view>
    <view class="info-row">
      <text class="info-label">所属企业</text>
      <text class="info-value">{{userInfo.enterpriseName || '-'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">企业类型</text>
      <text class="info-value">{{userInfo.enterpriseTypeName || '-'}}</text>
    </view>
  </view>

  <!-- 时间记录 -->
  <view class="info-section">
    <view class="section-title">时间记录</view>
    <view class="info-row">
      <text class="info-label">注册时间</text>
      <text class="info-value">{{userInfo.createTime}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">最近登录</text>
      <text class="info-value">{{userInfo.lastLoginTime || '从未登录'}}</text>
    </view>
    <view class="info-row">
      <text class="info-label">登录次数</text>
      <text class="info-value">{{userInfo.loginCount || 0}} 次</text>
    </view>
  </view>

  <!-- 冻结状态提示 -->
  <view class="frozen-notice" wx:if="{{userInfo.status === 0}}">
    <view class="notice-icon">!</view>
    <text class="notice-text">该账号已被冻结，请先解冻后再进行资料修改操作</text>
  </view>

  <!-- 底部操作按钮 -->
  <view class="action-buttons">
    <!-- 修改资料按钮 - 冻结状态禁用 -->
    <view class="action-btn edit-btn {{userInfo.status === 0 ? 'disabled' : ''}}" bindtap="openEditModal">
      <text>修改资料</text>
      <text class="disabled-hint" wx:if="{{userInfo.status === 0}}">当前状态下不可编辑</text>
    </view>
    <view class="action-btn {{userInfo.status === 1 ? 'freeze-btn' : 'unfreeze-btn'}}" bindtap="toggleStatus">
      <text>{{userInfo.status === 1 ? '冻结账号' : '解冻账号'}}</text>
    </view>
  </view>
</view>

<!-- 修改资料弹窗 -->
<view class="modal-overlay" wx:if="{{showEditModal}}" catchtouchmove="preventTouchMove">
  <view class="modal-content edit-modal" catchtouchmove="stopPropagation">
    <view class="modal-header">
      <text class="modal-title">修改用户资料</text>
      <view class="modal-close" bindtap="closeEditModal">x</view>
    </view>
    <scroll-view class="modal-body" scroll-y>
      <!-- 用户头像 -->
      <view class="edit-item">
        <text class="edit-label">用户头像</text>
        <view class="avatar-edit" bindtap="chooseAvatar">
          <image class="edit-avatar" src="{{editForm.avatar || 'https://via.placeholder.com/120/4CAF50/FFFFFF?text=U'}}" mode="aspectFill"></image>
          <view class="avatar-mask">
            <image class="camera-icon" src="/images/take-photo.png" mode="aspectFit"></image>
          </view>
        </view>
      </view>
      
      <!-- 真实姓名 -->
      <view class="edit-item">
        <text class="edit-label">真实姓名</text>
        <input class="edit-input" placeholder="请输入真实姓名" value="{{editForm.realName}}" bindinput="onEditInput" data-field="realName" maxlength="20"></input>
      </view>
      
      <!-- 昵称 -->
      <view class="edit-item">
        <text class="edit-label">用户昵称</text>
        <input class="edit-input" placeholder="请输入昵称" value="{{editForm.nickname}}" bindinput="onEditInput" data-field="nickname" maxlength="20"></input>
      </view>
      
      <!-- 手机号 -->
      <view class="edit-item">
        <text class="edit-label">手机号码</text>
        <input class="edit-input" placeholder="请输入手机号码" value="{{editForm.phone}}" bindinput="onEditInput" data-field="phone" type="number" maxlength="11"></input>
      </view>
      
      <!-- 邮箱 -->
      <view class="edit-item">
        <text class="edit-label">邮箱地址</text>
        <input class="edit-input" placeholder="请输入邮箱地址" value="{{editForm.email}}" bindinput="onEditInput" data-field="email" maxlength="50"></input>
      </view>
      
      <!-- 重置密码选项 -->
      <view class="edit-item reset-pwd-item">
        <view class="reset-pwd-row">
          <text class="edit-label">重置密码</text>
          <switch class="reset-switch" checked="{{editForm.resetPassword}}" bindchange="onResetSwitch" color="#4CAF50"></switch>
        </view>
        <text class="reset-hint" wx:if="{{editForm.resetPassword}}">保存后密码将重置为：123456</text>
      </view>
    </scroll-view>
    <view class="modal-footer">
      <view class="modal-btn cancel" bindtap="closeEditModal">取消</view>
      <view class="modal-btn confirm" bindtap="saveEdit">保存</view>
    </view>
  </view>
</view>
