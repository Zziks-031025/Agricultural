/* 用户管理页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: constant(safe-area-inset-bottom);
  padding-bottom: env(safe-area-inset-bottom);
  width: 100%;
  box-sizing: border-box;
  overflow-x: hidden;
}

/* ========== 统计卡片 ========== */
.stats-header {
  padding: 24rpx;
  background: #4CAF50;
}

.stats-card {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 32rpx 24rpx;
  backdrop-filter: blur(10rpx);
}

.stats-item {
  text-align: center;
  flex: 1;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-value.active {
  color: #8ECF92;
}

.stats-value.frozen {
  color: #FFB74D;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.2);
}

/* ========== 筛选区域 ========== */
.filter-section {
  background: #FFFFFF;
  padding: 24rpx;
  margin-bottom: 16rpx;
}

.search-box {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  margin-bottom: 20rpx;
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: #E0E0E0;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
}

.filter-tabs {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.tab-item {
  flex: 1;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
  transition: all 0.3s;
}

.tab-item.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  color: #2E7D32;
  font-weight: 500;
}

.role-filter {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.role-item {
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 24rpx;
  font-size: 24rpx;
  color: #666;
  transition: all 0.3s;
}

.role-item.active {
  background: #E8F5E9;
  color: #2E7D32;
}

/* ========== 用户列表 ========== */
.user-list {
  height: calc(100vh - 360rpx);
  padding: 0 24rpx;
  box-sizing: border-box;
}

.user-card {
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

/* 卡片头部 */
.card-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.user-info {
  flex: 1;
  min-width: 0;
  margin-right: 16rpx;
}

.user-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  line-height: 1.4;
}

.status-indicator {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.status-indicator.active {
  background: #4CAF50;
}

.status-indicator.frozen {
  background: #F44336;
}

.user-meta {
  display: flex;
  align-items: center;
  font-size: 24rpx;
  color: #888;
  overflow: hidden;
}

.user-account {
  color: #666;
}

.meta-divider {
  margin: 0 12rpx;
  color: #ddd;
}

.user-phone {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.role-tag {
  padding: 8rpx 16rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  font-weight: 500;
  flex-shrink: 0;
}

.role-1 {
  background: #E8F5E9;
  color: #2E7D32;
}

.role-2 {
  background: #E8F5E9;
  color: #4CAF50;
}

.role-3 {
  background: #F5F5F5;
  color: #757575;
}

/* 卡片内容 */
.card-body {
  padding: 16rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.info-grid {
  display: flex;
  justify-content: space-between;
}

.info-cell {
  flex: 1;
  text-align: center;
  position: relative;
}

.info-cell:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 48rpx;
  background: #EEEEEE;
}

.cell-label {
  display: block;
  font-size: 22rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.cell-value {
  display: block;
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 冻结提示 */
.frozen-notice {
  background: #FFFFFF;
  border-radius: 6rpx;
  padding: 12rpx 16rpx;
  margin-top: 12rpx;
  text-align: center;
}

.notice-text {
  font-size: 22rpx;
  color: #999999;
}

/* 卡片操作区 */
.card-actions {
  display: flex;
  align-items: center;
  justify-content: center;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
  margin-top: 4rpx;
}

.action-link {
  font-size: 28rpx;
  color: #2E7D32;
  padding: 8rpx 0;
}

.action-link:active {
  opacity: 0.7;
}

.action-link.danger {
  color: #F44336;
}

.action-link.success {
  color: #4CAF50;
}

.action-divider {
  width: 1rpx;
  height: 28rpx;
  background: #E0E0E0;
  margin: 0 32rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #BDBDBD;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
  font-size: 24rpx;
  color: #BDBDBD;
}

/* ========== 弹窗样式 ========== */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 9999;
}

.modal-content {
  width: 640rpx;
  max-height: 80vh;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: modalIn 0.3s ease-out;
  box-sizing: border-box;
}

@keyframes modalIn {
  from {
    transform: translateY(50rpx);
    opacity: 0;
  }
  to {
    transform: translateY(0);
    opacity: 1;
  }
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
  color: #999;
}

.modal-body {
  padding: 24rpx;
  max-height: 60vh;
  overflow-y: auto;
  box-sizing: border-box;
  width: 100%;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-btn {
  flex: 1;
  height: 96rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #F0F0F0;
}

.modal-btn.confirm {
  color: #4CAF50;
}

/* 重置密码弹窗 */
.reset-user-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #1a1a1a;
  text-align: center;
  margin-bottom: 24rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.reset-tips {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 20rpx;
  margin-bottom: 16rpx;
}

.reset-tips text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

.highlight {
  color: #F44336;
  font-weight: 600;
}

.reset-warning {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

/* 修改权限弹窗 */
.role-modal {
  width: 660rpx;
}

.role-user-info {
  text-align: center;
  padding-bottom: 24rpx;
  margin-bottom: 24rpx;
  border-bottom: 1rpx dashed #E0E0E0;
}

.role-user-name {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.role-user-current {
  font-size: 24rpx;
  color: #999;
}

.role-options {
  margin-bottom: 24rpx;
}

.role-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 16rpx;
}

.role-option {
  display: flex;
  align-items: center;
  padding: 24rpx 20rpx;
  background: #FAFAFA;
  border-radius: 8rpx;
  margin-bottom: 12rpx;
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.role-option.selected {
  background: #FFFFFF;
  border-color: #4CAF50;
}

.role-option:last-child {
  margin-bottom: 0;
}

.role-info {
  flex: 1;
}

.role-name {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 4rpx;
}

.role-desc {
  font-size: 22rpx;
  color: #999;
}

.role-check {
  width: 36rpx;
  height: 36rpx;
  background: #4CAF50;
  border-radius: 50%;
  color: #FFFFFF;
  font-size: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

/* 企业选择 */
.enterprise-select {
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 20rpx;
}

.select-title {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
}

.select-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  font-size: 28rpx;
  color: #333;
  padding: 16rpx 20rpx;
  background: #FFFFFF;
  border-radius: 8rpx;
  border: 1rpx solid #E0E0E0;
}

.select-arrow {
  font-size: 20rpx;
  color: #999;
}

/* 详情弹窗 */
.detail-modal {
  width: 660rpx;
  box-sizing: border-box;
}

.detail-modal .modal-body {
  max-height: 65vh;
  padding: 20rpx;
  box-sizing: border-box;
  -webkit-overflow-scrolling: touch;
}

.detail-modal .modal-body::-webkit-scrollbar {
  display: none;
  width: 0;
  height: 0;
}

.detail-header-section {
  padding-bottom: 20rpx;
  margin-bottom: 20rpx;
  border-bottom: 1rpx solid #F0F0F0;
  width: 100%;
  box-sizing: border-box;
}

.detail-name-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 8rpx;
}

.detail-main-name {
  font-size: 32rpx;
  font-weight: 600;
  color: #1a1a1a;
}

.detail-sub-info {
  font-size: 24rpx;
  color: #888;
}

.detail-status {
  padding: 6rpx 16rpx;
  border-radius: 4rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.detail-status.active {
  background: #E8F5E9;
  color: #4CAF50;
}

.detail-status.frozen {
  background: #FFEBEE;
  color: #F44336;
}

.detail-section {
  margin-bottom: 20rpx;
  width: 100%;
  box-sizing: border-box;
}

.detail-section:last-child {
  margin-bottom: 0;
}

.detail-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 16rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

.detail-item {
  display: flex;
  align-items: flex-start;
  padding: 12rpx 0;
  width: 100%;
  box-sizing: border-box;
}

.detail-label {
  width: 140rpx;
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
}

.detail-value {
  flex: 1;
  font-size: 26rpx;
  color: #333;
  word-break: break-all;
  overflow-wrap: break-word;
  min-width: 0;
}

.detail-value.clickable {
  color: #2196F3;
}
