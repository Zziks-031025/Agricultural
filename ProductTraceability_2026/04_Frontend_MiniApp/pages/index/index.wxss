/* ========================================
   首页样式 - 游客/企业 统一布局
   ======================================== */

/* ---- 页面容器 ---- */
.page-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========================================
   头部区域 - 绿色渐变背景
   ======================================== */
.brand-header {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 40rpx 30rpx 100rpx;
  position: relative;
}

.brand-header::before {
  content: '';
  position: absolute;
  top: -50rpx;
  right: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.header-content {
  position: relative;
  z-index: 1;
}

/* ---- 游客头部 ---- */
.guest-brand {
  padding: 10rpx 0;
}

.guest-logo-row {
  display: flex;
  align-items: center;
}

.guest-logo {
  width: 80rpx;
  height: 80rpx;
  margin-right: 20rpx;
  border-radius: 16rpx;
}

.guest-title-group {
  display: flex;
  flex-direction: column;
}

.guest-title {
  font-size: 42rpx;
  font-weight: bold;
  color: #FFFFFF;
  line-height: 1.2;
}

.guest-subtitle {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-top: 6rpx;
  letter-spacing: 2rpx;
}

/* ---- 企业头部 ---- */
.brand-info {
  margin-bottom: 10rpx;
}

.brand-name-row {
  display: flex;
  align-items: center;
  margin-bottom: 10rpx;
}

.brand-name {
  font-size: 42rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 16rpx;
}

.certified-badge {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.25);
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.3);
}

.badge-icon {
  font-size: 20rpx;
  color: #FFFFFF;
  margin-right: 6rpx;
  font-weight: bold;
}

.badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.brand-slogan {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  letter-spacing: 1rpx;
}

/* ========================================
   轮播图 - 白色卡片浮层
   ======================================== */
.brand-swiper-card {
  margin: -70rpx 30rpx 0;
  position: relative;
  z-index: 2;
  border-radius: 20rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.brand-swiper {
  width: 100%;
  height: 300rpx;
}

.swiper-item-content {
  width: 100%;
  height: 100%;
  position: relative;
}

.swiper-bg {
  width: 100%;
  height: 100%;
}

.swiper-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 30rpx 24rpx 20rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.65), transparent);
}

.swiper-title {
  display: block;
  font-size: 32rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 6rpx;
}

.swiper-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ========================================
   数据统计看板 - 白色卡片
   ======================================== */
.blockchain-dashboard {
  display: flex;
  align-items: center;
  margin: 24rpx 30rpx 0;
  padding: 30rpx 24rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.dashboard-card {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-info {
  text-align: center;
}

.card-value {
  display: block;
  font-size: 48rpx;
  font-weight: bold;
  color: #4CAF50;
  font-family: 'DIN Alternate', 'Helvetica Neue', sans-serif;
  line-height: 1.1;
}

.enterprise-value {
  color: #FF9800;
}

.contribute-value {
  color: #1976D2;
}

.card-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-top: 4rpx;
}

.dashboard-divider {
  width: 1rpx;
  height: 60rpx;
  background: #E0E0E0;
  margin: 0 20rpx;
}

/* ========================================
   扫码溯源按钮（所有人可用）
   ======================================== */
.scan-section {
  display: flex;
  justify-content: center;
  padding: 60rpx 40rpx;
}

.scan-btn {
  width: 500rpx;
  height: 500rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 20rpx 60rpx rgba(76, 175, 80, 0.4);
  position: relative;
  overflow: hidden;
}

.scan-btn::before {
  content: '';
  position: absolute;
  top: -50%;
  left: -50%;
  width: 200%;
  height: 200%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.2) 0%, transparent 70%);
  animation: pulse 2s ease-in-out infinite;
}

@keyframes pulse {
  0%, 100% {
    transform: scale(0.8);
    opacity: 0.5;
  }
  50% {
    transform: scale(1.2);
    opacity: 0.8;
  }
}

.scan-btn-hover {
  transform: scale(0.96);
  opacity: 0.9;
}

.scan-icon-consumer {
  width: 160rpx;
  height: 160rpx;
  margin-bottom: 20rpx;
}

.scan-text {
  font-size: 48rpx;
  color: #fff;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.scan-hint {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
  text-align: center;
}

/* ========================================
   平台简介（仅游客）
   ======================================== */
.intro-section {
  padding: 40rpx;
  background: #fff;
  margin: 0 30rpx 24rpx;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.intro-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.intro-line {
  width: 60rpx;
  height: 4rpx;
  background: linear-gradient(to right, transparent, #4CAF50);
}

.intro-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin: 0 20rpx;
}

.intro-content {
  text-align: justify;
}

.intro-text {
  font-size: 28rpx;
  line-height: 48rpx;
  color: #555;
  margin-bottom: 30rpx;
}

.highlight {
  color: #2E7D32;
  font-weight: bold;
}

.intro-features {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.feature-tag {
  display: flex;
  align-items: center;
  background: #E8F5E9;
  padding: 16rpx 24rpx;
  border-radius: 40rpx;
  border: 2rpx solid #4CAF50;
}

.feature-icon {
  font-size: 24rpx;
  color: #4CAF50;
  margin-right: 8rpx;
}

.feature-text {
  font-size: 24rpx;
  color: #2E7D32;
}

/* ========================================
   底部导航区（所有人可用）
   ======================================== */
.bottom-nav {
  display: flex;
  align-items: center;
  margin: 0 30rpx;
  padding: 28rpx 20rpx;
  background: #FFFFFF;
  border-radius: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.nav-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx;
}

.nav-icon-wrapper {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 14rpx;
}

.nav-icon {
  width: 60rpx;
  height: 60rpx;
}

.nav-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 4rpx;
}

.nav-desc {
  font-size: 22rpx;
  color: #999;
}

.nav-divider {
  width: 1rpx;
  height: 70rpx;
  background: #E8E8E8;
  margin: 0 16rpx;
}

/* ========================================
   底部标识
   ======================================== */
.brand-footer {
  padding: 30rpx 40rpx 20rpx;
  text-align: center;
}

.footer-text {
  font-size: 22rpx;
  color: #AAAAAA;
  letter-spacing: 1rpx;
}
