.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #E8F5E9 0%, #F5F5F5 30%);
}

/* 页面头部 */
.page-header {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  padding: 40rpx 30rpx;
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.header-content {
  flex: 1;
}

.header-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.header-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.header-stats {
  background: rgba(255, 255, 255, 0.2);
  border-radius: 12rpx;
  padding: 16rpx 24rpx;
  text-align: center;
}

.stats-num {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
}

.stats-text {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* 筛选区域 */
.filter-section {
  display: flex;
  background: #FFFFFF;
  padding: 20rpx;
  margin: 20rpx;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.06);
  gap: 12rpx;
}

.filter-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 16rpx 8rpx;
  border-radius: 12rpx;
  background: #F5F5F5;
  transition: all 0.3s;
}

.filter-item.active {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  box-shadow: 0 2rpx 8rpx rgba(76, 175, 80, 0.2);
}

.filter-icon {
  width: 40rpx;
  height: 40rpx;
  margin-bottom: 6rpx;
}

.filter-item text {
  font-size: 22rpx;
  color: #666;
}

.filter-item.active text {
  color: #2E7D32;
  font-weight: 500;
}

/* 企业列表 */
.enterprise-list {
  height: calc(100vh - 320rpx);
  padding: 0 20rpx 20rpx;
  box-sizing: border-box;
  width: 100%;
}

.enterprise-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  position: relative;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.enterprise-card::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: linear-gradient(180deg, #4CAF50 0%, #81C784 100%);
}

.card-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

/* 种植养殖 - 绿色 */
.card-logo.type-1 {
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
}

/* 加工宰杀 - 橙色 */
.card-logo.type-2 {
  background: linear-gradient(135deg, #FFF3E0 0%, #FFE0B2 100%);
}

/* 检疫质检 - 蓝色 */
.card-logo.type-3 {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.logo-img {
  width: 56rpx;
  height: 56rpx;
}

.card-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  overflow: hidden;
}

.info-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.enterprise-name {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  flex: 1;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-right: 12rpx;
}

.certified-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  padding: 6rpx 14rpx;
  border-radius: 20rpx;
  flex-shrink: 0;
}

.certified-tag .tag-icon {
  width: 24rpx;
  height: 24rpx;
  background: #FFFFFF;
  border-radius: 50%;
  font-size: 16rpx;
  color: #4CAF50;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 6rpx;
}

.certified-tag .tag-text {
  font-size: 20rpx;
  color: #FFFFFF;
  font-weight: 500;
}

.info-meta {
  display: flex;
  gap: 24rpx;
  margin-bottom: 12rpx;
  overflow: hidden;
}

.meta-item {
  display: flex;
  flex-direction: column;
}

.meta-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 4rpx;
}

.meta-value {
  font-size: 24rpx;
  color: #333;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.meta-value.highlight {
  color: #4CAF50;
}

.info-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  overflow: hidden;
}

.location {
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  min-width: 0;
}

.view-detail {
  font-size: 24rpx;
  color: #4CAF50;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12rpx;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* 加载状态 */
.loading-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
}

.loading-spinner {
  width: 40rpx;
  height: 40rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 16rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* 没有更多 */
.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more text {
  font-size: 24rpx;
  color: #BDBDBD;
}
