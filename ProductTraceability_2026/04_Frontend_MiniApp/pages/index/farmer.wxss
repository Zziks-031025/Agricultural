/* 肉鸡养殖户专属首页样式 - 生态绿配色 */

/* 主色调定义 */
page {
  --primary-green: #2E7D32;
  --primary-green-light: #4CAF50;
  --primary-green-dark: #1B5E20;
  --accent-green: #81C784;
  --bg-green-light: #E8F5E9;
  --bg-green-gradient: linear-gradient(180deg, #E8F5E9 0%, #F1F8E9 50%, #FAFAFA 100%);
}

.farmer-container {
  min-height: 100vh;
  background: var(--bg-green-gradient);
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* ========== 身份确认区 ========== */
.identity-section {
  position: relative;
  padding: 60rpx 40rpx 80rpx;
  overflow: hidden;
}

.identity-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: linear-gradient(135deg, var(--primary-green) 0%, var(--primary-green-light) 50%, #66BB6A 100%);
  border-radius: 0 0 60rpx 60rpx;
}

.identity-bg::before {
  content: '';
  position: absolute;
  top: -100rpx;
  right: -100rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.15) 0%, transparent 70%);
  border-radius: 50%;
}

.identity-bg::after {
  content: '';
  position: absolute;
  bottom: -50rpx;
  left: -50rpx;
  width: 200rpx;
  height: 200rpx;
  background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
  border-radius: 50%;
}

.identity-content {
  position: relative;
  z-index: 1;
}

.welcome-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.welcome-text {
  display: flex;
  flex-direction: column;
}

.welcome-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 8rpx;
}

.enterprise-name {
  font-size: 44rpx;
  font-weight: bold;
  color: #FFFFFF;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.enterprise-logo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.identity-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.certified-tag {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #43A047 0%, #66BB6A 100%);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  box-shadow: 0 4rpx 12rpx rgba(67, 160, 71, 0.4);
}

.tag-icon {
  font-size: 24rpx;
  color: #FFFFFF;
  margin-right: 8rpx;
  font-weight: bold;
}

.tag-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 600;
}

.type-tag {
  background: rgba(255, 255, 255, 0.2);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.3);
}

.type-text {
  font-size: 24rpx;
  color: #FFFFFF;
}

.chain-tag {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  padding: 10rpx 24rpx;
  border-radius: 30rpx;
}

.chain-icon {
  font-size: 22rpx;
  margin-right: 6rpx;
}

.chain-text {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.9);
}

/* ========== 区块链数据看板 ========== */
.stats-dashboard {
  display: flex;
  gap: 24rpx;
  padding: 0 30rpx;
  margin-top: -50rpx;
  position: relative;
  z-index: 2;
}

.stats-card {
  flex: 1;
  background: #FFFFFF;
  border-radius: 24rpx;
  padding: 28rpx 24rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.08);
  display: flex;
  align-items: center;
  position: relative;
  overflow: hidden;
}

.stats-card::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--primary-green-light), var(--accent-green));
}

.stats-icon-wrapper {
  width: 90rpx;
  height: 90rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, var(--bg-green-light) 0%, #C8E6C9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.farm-icon {
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.stats-icon {
  width: 50rpx;
  height: 50rpx;
}

.stats-info {
  flex: 1;
  min-width: 0;
}

.stats-label {
  display: block;
  font-size: 22rpx;
  color: #888;
  margin-bottom: 8rpx;
}

.stats-value-row {
  display: flex;
  align-items: baseline;
  margin-bottom: 6rpx;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: var(--primary-green);
  font-family: 'DIN Alternate', 'Helvetica Neue', sans-serif;
  line-height: 1;
}

.farm-value {
  color: #1976D2;
}

.stats-unit {
  font-size: 22rpx;
  color: #999;
  margin-left: 6rpx;
}

.stats-trend {
  display: flex;
  align-items: center;
}

.trend-icon {
  font-size: 20rpx;
  color: var(--primary-green-light);
  margin-right: 4rpx;
}

.trend-text {
  font-size: 20rpx;
  color: var(--primary-green-light);
}

.stats-detail {
  margin-top: 2rpx;
}

.detail-text {
  font-size: 20rpx;
  color: #999;
}

/* ========== 核心交互 - 扫码溯源 ========== */
.scan-section {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 80rpx 0;
  position: relative;
}

.scan-ring {
  position: absolute;
  border-radius: 50%;
  border: 2rpx solid rgba(76, 175, 80, 0.15);
}

.scan-ring-outer {
  width: 580rpx;
  height: 580rpx;
  animation: ringPulse 3s ease-in-out infinite;
}

.scan-ring-middle {
  width: 520rpx;
  height: 520rpx;
  animation: ringPulse 3s ease-in-out infinite 0.5s;
}

.scan-ring-inner {
  width: 460rpx;
  height: 460rpx;
  animation: ringPulse 3s ease-in-out infinite 1s;
}

@keyframes ringPulse {
  0%, 100% {
    opacity: 0.3;
    transform: scale(0.95);
  }
  50% {
    opacity: 0.6;
    transform: scale(1.05);
  }
}

.scan-btn {
  width: 380rpx;
  height: 380rpx;
  background: linear-gradient(145deg, var(--primary-green-light) 0%, var(--primary-green) 100%);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  box-shadow: 
    0 20rpx 60rpx rgba(46, 125, 50, 0.35),
    0 8rpx 24rpx rgba(46, 125, 50, 0.25),
    inset 0 -4rpx 12rpx rgba(0, 0, 0, 0.1),
    inset 0 4rpx 12rpx rgba(255, 255, 255, 0.2);
  z-index: 1;
}

.scan-btn::before {
  content: '';
  position: absolute;
  top: 10rpx;
  left: 10rpx;
  right: 10rpx;
  bottom: 10rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.15);
}

.scan-pulse {
  position: absolute;
  width: 100%;
  height: 100%;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.4) 0%, transparent 70%);
  animation: pulse 2.5s ease-out infinite;
}

.scan-pulse-delay {
  animation-delay: 1.25s;
}

@keyframes pulse {
  0% {
    transform: scale(0.8);
    opacity: 0.8;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.scan-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  position: relative;
  z-index: 2;
}

.scan-icon {
  width: 120rpx;
  height: 120rpx;
  margin-bottom: 16rpx;
  filter: brightness(0) invert(1);
}

.scan-text {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.15);
}

.scan-hint {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.85);
}

/* ========== 快捷功能入口 ========== */
.quick-actions {
  display: flex;
  justify-content: space-between;
  padding: 0 30rpx;
  margin-bottom: 40rpx;
}

.action-item {
  flex: 1;
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  margin: 0 10rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
  transition: all 0.3s ease;
}

.action-item:active {
  transform: scale(0.98);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.action-icon-wrapper {
  width: 88rpx;
  height: 88rpx;
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.action-green {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.action-blue {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
}

.action-orange {
  background: linear-gradient(135deg, #FFE0B2 0%, #FFCC80 100%);
}

.action-icon {
  width: 48rpx;
  height: 48rpx;
}

.action-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
}

.action-desc {
  font-size: 20rpx;
  color: #999;
}

/* ========== 内容引导九宫格 ========== */
.content-section {
  padding: 0 30rpx 30rpx;
}

.section-header {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
}

.header-line {
  width: 80rpx;
  height: 4rpx;
  background: linear-gradient(90deg, transparent, var(--primary-green-light), transparent);
  border-radius: 2rpx;
}

.header-title {
  font-size: 32rpx;
  font-weight: bold;
  color: var(--primary-green-dark);
  margin: 0 24rpx;
}

.grid-container {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.grid-item {
  width: calc((100% - 40rpx) / 3);
  background: #FFFFFF;
  border-radius: 20rpx;
  padding: 28rpx 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.05);
  transition: all 0.3s ease;
}

.grid-item:active {
  transform: scale(0.96);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.08);
}

.grid-icon-wrapper {
  width: 80rpx;
  height: 80rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
}

.grid-green {
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
}

.grid-yellow {
  background: linear-gradient(135deg, #FFF9C4 0%, #FFF59D 100%);
}

.grid-blue {
  background: linear-gradient(135deg, #BBDEFB 0%, #90CAF9 100%);
}

.grid-purple {
  background: linear-gradient(135deg, #E1BEE7 0%, #CE93D8 100%);
}

.grid-red {
  background: linear-gradient(135deg, #FFCDD2 0%, #EF9A9A 100%);
}

.grid-teal {
  background: linear-gradient(135deg, #B2DFDB 0%, #80CBC4 100%);
}

.grid-amber {
  background: linear-gradient(135deg, #FFE082 0%, #FFD54F 100%);
}

.grid-indigo {
  background: linear-gradient(135deg, #C5CAE9 0%, #9FA8DA 100%);
}

.grid-dark-green {
  background: linear-gradient(135deg, #A5D6A7 0%, #81C784 100%);
}

.grid-icon {
  width: 44rpx;
  height: 44rpx;
}

.grid-name {
  font-size: 26rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 6rpx;
  text-align: center;
}

.grid-desc {
  font-size: 20rpx;
  color: #999;
  text-align: center;
  line-height: 1.3;
}

/* ========== 底部安全提示 ========== */
.footer-tips {
  padding: 30rpx 40rpx;
}

.tips-content {
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(90deg, rgba(46, 125, 50, 0.08) 0%, rgba(76, 175, 80, 0.12) 50%, rgba(46, 125, 50, 0.08) 100%);
  padding: 20rpx 30rpx;
  border-radius: 40rpx;
  border: 2rpx solid rgba(76, 175, 80, 0.2);
}

.tips-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.tips-text {
  font-size: 22rpx;
  color: var(--primary-green);
  line-height: 1.5;
}
