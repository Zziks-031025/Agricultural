<!-- 企业详情页 - 消费者视角 -->
<view class="container">
  <!-- 企业头部 -->
  <view class="enterprise-header">
    <image class="cover-image" src="{{enterpriseInfo.coverImage || 'https://via.placeholder.com/750x400/4CAF50/FFFFFF?text=企业实景'}}" mode="aspectFill"></image>
    <view class="header-overlay">
      <view class="header-content">
        <view class="enterprise-logo">
          <image class="logo-img" src="{{enterpriseInfo.logo || '/images/enterprise-icon.png'}}" mode="aspectFill"></image>
        </view>
        <view class="enterprise-title">
          <text class="enterprise-name">{{enterpriseInfo.enterpriseName}}</text>
          <view class="certified-badge">
            <text class="badge-icon">V</text>
            <text class="badge-text">已通过认证</text>
          </view>
        </view>
      </view>
    </view>
  </view>

  <!-- 区块链信用背书 -->
  <view class="blockchain-credit">
    <view class="credit-header">
      <image class="credit-icon" src="/images/Blockchain.png" mode="aspectFit"></image>
      <text class="credit-title">区块链信用背书</text>
    </view>
    <view class="credit-stats">
      <view class="stat-item main">
        <text class="stat-value">{{enterpriseInfo.chainCount || 0}}</text>
        <text class="stat-label">累计存证笔数</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{enterpriseInfo.batchCount || 0}}</text>
        <text class="stat-label">溯源批次</text>
      </view>
      <view class="stat-divider"></view>
      <view class="stat-item">
        <text class="stat-value">{{enterpriseInfo.verifyCount || 0}}</text>
        <text class="stat-label">验真次数</text>
      </view>
    </view>
    <view class="credit-footer">
      <text class="credit-note">以上数据均已通过以太坊区块链存证，不可篡改</text>
    </view>
  </view>

  <!-- 基本信息 -->
  <view class="info-section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">基本信息</text>
    </view>
    <view class="info-card">
      <view class="info-row">
        <text class="info-label">企业类型</text>
        <text class="info-value">{{enterpriseInfo.enterpriseTypeName}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">统一社会信用代码</text>
        <text class="info-value mono">{{enterpriseInfo.creditCode}}</text>
      </view>
      <view class="info-row">
        <text class="info-label">法人代表</text>
        <text class="info-value">{{enterpriseInfo.legalPerson}}</text>
      </view>
      <view class="info-row" wx:if="{{enterpriseInfo.introduction}}">
        <text class="info-label">企业简介</text>
        <text class="info-value intro">{{enterpriseInfo.introduction}}</text>
      </view>
    </view>
  </view>

  <!-- 资质证件 -->
  <view class="info-section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">资质证件</text>
    </view>
    <view class="license-card">
      <view class="license-item" bindtap="previewImage" data-url="{{enterpriseInfo.businessLicense}}">
        <image class="license-img" src="{{enterpriseInfo.businessLicense || 'https://via.placeholder.com/300x200/E8F5E9/4CAF50?text=营业执照'}}" mode="aspectFill"></image>
        <view class="license-label">
          <text>营业执照</text>
          <text class="view-hint">点击查看大图</text>
        </view>
      </view>
      <view class="license-item" bindtap="previewImage" data-url="{{enterpriseInfo.productionLicense}}">
        <image class="license-img" src="{{enterpriseInfo.productionLicense || 'https://via.placeholder.com/300x200/E3F2FD/42A5F5?text=许可证'}}" mode="aspectFill"></image>
        <view class="license-label">
          <text>行业许可证</text>
          <text class="view-hint">点击查看大图</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 联系信息 -->
  <view class="info-section">
    <view class="section-header">
      <view class="section-line"></view>
      <text class="section-title">联系信息</text>
    </view>
    <view class="contact-card">
      <view class="contact-item">
        <view class="contact-icon-wrapper">
          <image class="contact-icon" src="/images/position.png" mode="aspectFit"></image>
        </view>
        <view class="contact-info">
          <text class="contact-label">企业地址</text>
          <text class="contact-value">{{enterpriseInfo.address}}</text>
        </view>
      </view>
      <view class="contact-item clickable" bindtap="callPhone">
        <view class="contact-icon-wrapper phone">
          <image class="contact-icon" src="/images/service-hotline.png" mode="aspectFit"></image>
        </view>
        <view class="contact-info">
          <text class="contact-label">联系电话</text>
          <text class="contact-value phone">{{enterpriseInfo.contactPhone}}</text>
        </view>
        <view class="call-btn">
          <text>拨打</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 底部声明 -->
  <view class="footer-statement">
    <view class="statement-icon">i</view>
    <text class="statement-text">本页面信息由企业自主提交，经平台审核后公示。如有疑问，请联系平台客服。</text>
  </view>
</view>
