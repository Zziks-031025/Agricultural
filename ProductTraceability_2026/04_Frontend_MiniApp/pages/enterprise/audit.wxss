.audit-container {
  min-height: 100vh;
  background: #F1F8E9;
  padding: 20rpx;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

.enterprise-header {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.header-content {
  display: flex;
  align-items: center;
}

.enterprise-avatar {
  width: 100rpx;
  height: 100rpx;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-img {
  width: 64rpx;
  height: 64rpx;
}

.header-info {
  flex: 1;
  min-width: 0;
}

.enterprise-name {
  font-size: 36rpx;
  font-weight: bold;
  color: #fff;
  margin-bottom: 12rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.audit-status {
  display: inline-block;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  color: #fff;
}

.status-0 {
  background: rgba(255, 152, 0, 0.9);
}

.status-1 {
  background: rgba(255, 255, 255, 0.3);
}

.status-2 {
  background: rgba(244, 67, 54, 0.9);
}

.info-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E8F5E9;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
  box-sizing: border-box;
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  width: 200rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
  text-align: right;
  flex: 1;
  min-width: 0;
  word-break: break-all;
}

.info-value.clickable {
  color: #4CAF50;
  text-decoration: underline;
}

.info-value.intro {
  text-align: left;
  line-height: 1.6;
  color: #666;
}

/* 区块链存证统计 */
.chain-stats {
  display: flex;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 12rpx;
  padding: 24rpx;
}

.chain-stats .stat-item {
  flex: 1;
  text-align: center;
}

.chain-stats .stat-value {
  display: block;
  font-size: 44rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 8rpx;
}

.chain-stats .stat-label {
  display: block;
  font-size: 24rpx;
  color: #666;
}

/* 证件区域 */
.certificate-item {
  margin-bottom: 32rpx;
  box-sizing: border-box;
}

.certificate-item:last-child {
  margin-bottom: 0;
}

.cert-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
  font-weight: 500;
}

.cert-images {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.cert-img-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  border: 2rpx solid #E0E0E0;
}

.cert-img {
  width: 100%;
  height: 100%;
}

.reject-reason {
  background: #FFF3E0;
  border: 1rpx solid #FFE082;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #F57C00;
  line-height: 1.6;
  box-sizing: border-box;
}

/* 底部操作按钮 */
.audit-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 12rpx rgba(0, 0, 0, 0.1);
  box-sizing: border-box;
  z-index: 100;
}

.audit-actions.disabled-hint {
  justify-content: center;
  background: #FFF3E0;
}

.hint-text {
  font-size: 28rpx;
  color: #F57C00;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-sizing: border-box;
}

.reject-btn {
  background: #fff;
  color: #F44336;
  border: 2rpx solid #F44336;
}

.approve-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.edit-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #fff;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

/* 弹窗样式 */
.modal-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 1000;
  display: flex;
  align-items: center;
  justify-content: center;
}

.modal-content {
  width: 640rpx;
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.modal-content.edit-modal {
  max-height: 80vh;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
  background: #FAFAFA;
}

.modal-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.modal-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.modal-body {
  padding: 24rpx;
}

.modal-body.edit-body {
  max-height: 60vh;
  padding: 24rpx;
}

.reject-textarea {
  width: 100%;
  min-height: 200rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-btn {
  flex: 1;
  height: 88rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 500;
}

.modal-btn.cancel {
  color: #666;
  background: #FAFAFA;
}

.modal-btn.confirm {
  color: #FFFFFF;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
}

/* 编辑表单样式 */
.edit-item {
  margin-bottom: 28rpx;
}

.edit-item:last-child {
  margin-bottom: 0;
}

.edit-label {
  display: block;
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  font-weight: 500;
}

.avatar-edit {
  position: relative;
  width: 140rpx;
  height: 140rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.edit-avatar {
  width: 100%;
  height: 100%;
}

.avatar-mask {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 50rpx;
  background: rgba(0, 0, 0, 0.5);
  display: flex;
  align-items: center;
  justify-content: center;
}

.camera-icon {
  width: 32rpx;
  height: 32rpx;
}

.edit-textarea {
  width: 100%;
  min-height: 160rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  line-height: 1.6;
}

.edit-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
}
