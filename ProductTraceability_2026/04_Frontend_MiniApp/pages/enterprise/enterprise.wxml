<view class="enterprise-container">
  <view class="page-header">
    <view class="header-subtitle">待审核企业列表</view>
  </view>

  <view class="enterprise-list" wx:if="{{!isEmpty && !loading}}">
    <view class="enterprise-item" wx:for="{{enterpriseList}}" wx:key="id" bindtap="goToDetail" data-id="{{item.id}}">
      <view class="item-header">
        <view class="enterprise-name">{{item.enterpriseName}}</view>
        <view class="enterprise-type type-{{item.enterpriseType}}">{{item.enterpriseTypeName}}</view>
      </view>
      <view class="item-info">
        <view class="info-item">
          <text class="info-label">申请时间</text>
          <text class="info-value">{{item.applyTime}}</text>
        </view>
      </view>
      <view class="item-footer">
        <view class="status-badge status-pending">待审核</view>
        <view class="arrow-icon">›</view>
      </view>
    </view>
  </view>

  <view class="empty-state" wx:if="{{isEmpty && !loading}}">
    <image class="empty-icon" src="https://via.placeholder.com/200/E0E0E0/999?text=Empty" mode="aspectFit"></image>
    <view class="empty-text">暂无待审核企业</view>
  </view>

  <view class="loading-state" wx:if="{{loading}}">
    <view class="loading-text">加载中...</view>
  </view>
</view>
