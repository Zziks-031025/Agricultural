.storage-container {
  min-height: 100vh;
  background: #F1F8E9;
  padding-bottom: 180rpx;
}

.input-mode-tabs {
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

.tabs-container {
  width: 90%;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 6rpx;
  display: flex;
  gap: 6rpx;
}

.mode-tab {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.mode-text {
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.mode-tab.active {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.mode-tab.active .mode-text {
  color: #2E7D32;
  font-weight: bold;
}

.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx 34rpx;
  margin: 0 30rpx 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
  overflow: visible;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E8F5E9;
}

.batch-input-area {
  margin-bottom: 20rpx;
  overflow: visible;
}

.scan-btn {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 12rpx;
  padding: 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
}

.scan-icon {
  width: 100rpx;
  height: 100rpx;
  margin-bottom: 20rpx;
}

.scan-text {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.input-group {
  display: flex;
  gap: 20rpx;
}

.batch-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.confirm-btn {
  width: 160rpx;
  height: 88rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.batch-info-card {
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 24rpx;
}

.info-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid rgba(46, 125, 50, 0.1);
}

.info-row:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #666;
}

.info-value {
  font-size: 26rpx;
  color: #2E7D32;
  font-weight: 500;
  text-align: right;
  flex: 1;
  margin-left: 20rpx;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label.required::before {
  content: '*';
  color: #FF5252;
  margin-right: 4rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  width: 100%;
}

.form-picker .placeholder {
  color: #BDBDBD;
}

.picker-arrow {
  color: #BDBDBD;
  font-size: 28rpx;
  flex-shrink: 0;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.form-input {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.form-textarea {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  width: 100%;
  height: 160rpx;
  box-sizing: border-box;
}

.textarea-count {
  text-align: right;
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.location-btn {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.location-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.location-text {
  font-size: 28rpx;
  color: #2E7D32;
  flex: 1;
}

.environment-tip {
  background: #FFFFFF;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  padding: 20rpx;
  display: flex;
  align-items: flex-start;
  margin-top: 20rpx;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.tip-text {
  font-size: 24rpx;
  color: #999999;
  line-height: 1.6;
  flex: 1;
}

.photo-area {
  display: flex;
  flex-direction: column;
  overflow: visible;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
  overflow: visible;
}

.image-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
  border-radius: 12rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 48rpx;
  height: 48rpx;
  background: rgba(0, 0, 0, 0.6);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #FFFFFF;
  font-size: 40rpx;
  line-height: 1;
}

.upload-btn {
  width: 200rpx;
  height: 200rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  margin: 0;
}

.camera-icon {
  width: 60rpx;
  height: 60rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 24rpx;
  color: #4CAF50;
}

.upload-tip {
  font-size: 24rpx;
  color: #999;
  text-align: center;
}

.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.05);
  z-index: 99;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.reset-btn {
  background: #FFFFFF;
  color: #666;
  border: 2rpx solid #E0E0E0;
}

.submit-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.quantity-hint-text {
  font-size: 24rpx;
  color: #909399;
  margin-top: 8rpx;
  line-height: 1.4;
}
