.processing-container {
  min-height: 100vh;
  background: #F1F8E9;
  padding: 20rpx;
  padding-bottom: 40rpx;
  box-sizing: border-box;
}

/* ========== Section ========== */
.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  box-sizing: border-box;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E8F5E9;
}

/* ========== Batch Card ========== */
.batch-card {
  background: #E8F5E9;
  border-radius: 12rpx;
  padding: 20rpx;
}

.batch-header {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.batch-tag {
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 22rpx;
  font-weight: bold;
  padding: 4rpx 14rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.batch-code {
  font-size: 28rpx;
  font-weight: bold;
  color: #2E7D32;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.batch-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 0;
}

.batch-field {
  width: 50%;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.batch-field:nth-child(odd) {
  padding-right: 8rpx;
}

.batch-field:nth-child(even) {
  padding-left: 8rpx;
}

.field-label {
  font-size: 22rpx;
  color: #81C784;
  display: block;
}

.field-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.batch-change {
  margin-top: 12rpx;
  text-align: right;
}

.change-text {
  font-size: 24rpx;
  color: #4CAF50;
  text-decoration: underline;
}

/* ========== Scan Area ========== */
.scan-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx 20rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx dashed #4CAF50;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.scan-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 12rpx;
}

.scan-tip {
  font-size: 28rpx;
  color: #4CAF50;
  font-weight: 500;
}

.divider-row {
  display: flex;
  align-items: center;
  margin: 16rpx 0;
}

.divider-line {
  flex: 1;
  height: 1rpx;
  background: #E0E0E0;
}

.divider-text {
  font-size: 24rpx;
  color: #999;
  padding: 0 20rpx;
}

.manual-input-row {
  display: flex;
  gap: 16rpx;
  align-items: center;
}

.batch-input {
  flex: 1;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 80rpx;
  line-height: 80rpx;
  font-size: 28rpx;
  color: #333;
}

.confirm-btn-small {
  width: 140rpx;
  height: 80rpx;
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  font-size: 28rpx;
  font-weight: bold;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  line-height: 80rpx;
}

/* ========== Form ========== */
.form-item {
  margin-bottom: 24rpx;
  box-sizing: border-box;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label.required::before {
  content: '*';
  color: #FF5252;
  margin-right: 4rpx;
}

.form-picker {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 88rpx;
  display: flex;
  align-items: center;
  box-sizing: border-box;
}

.picker-value {
  font-size: 28rpx;
  color: #333;
}

.picker-value.placeholder {
  color: #C0C0C0;
}

.form-input {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 0 24rpx;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 28rpx;
  color: #333;
  box-sizing: border-box;
  width: 100%;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: #F5F5F5;
  border-radius: 8rpx;
  padding-right: 24rpx;
  height: 88rpx;
}

.input-with-unit .form-input {
  flex: 1;
  background: transparent;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 24rpx;
  min-width: 0;
}

.unit-text {
  font-size: 28rpx;
  color: #999;
  flex-shrink: 0;
  margin-left: 12rpx;
}

.unit-picker {
  flex-shrink: 0;
  margin-left: 8rpx;
}

.unit-selectable {
  color: #4CAF50;
  font-weight: 500;
  padding: 4rpx 12rpx;
  background: #E8F5E9;
  border-radius: 6rpx;
}

.form-textarea {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
  min-height: 140rpx;
  width: 100%;
  box-sizing: border-box;
}

/* ========== Photo Grid ========== */
.photo-tip {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 20rpx;
}

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
  flex-shrink: 0;
}

.photo-img {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 6rpx;
  right: 6rpx;
  width: 44rpx;
  height: 44rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-x {
  color: #FFFFFF;
  font-size: 32rpx;
  line-height: 1;
}

.photo-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #4CAF50;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  flex-shrink: 0;
}

.photo-add-album {
  border-color: #90CAF9;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.camera-icon {
  width: 52rpx;
  height: 52rpx;
  margin-bottom: 8rpx;
}

.album-icon {
  font-size: 52rpx;
  color: #42A5F5;
  font-weight: 300;
  line-height: 1;
  margin-bottom: 4rpx;
}

.add-text {
  font-size: 24rpx;
  color: #4CAF50;
}

.photo-add-album .add-text {
  color: #42A5F5;
}

/* ========== Blockchain Hint ========== */
.chain-hint {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #E0F2F1 0%, #B2DFDB 100%);
  border: 1rpx solid #80CBC4;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 20rpx;
}

.chain-hint-icon {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: #00796B;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.chain-icon-text {
  color: #FFFFFF;
  font-size: 20rpx;
  font-weight: bold;
}

.chain-hint-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.chain-hint-title {
  font-size: 26rpx;
  font-weight: bold;
  color: #00695C;
}

.chain-hint-desc {
  font-size: 22rpx;
  color: #4DB6AC;
}

/* ========== Actions ========== */
.form-actions {
  display: flex;
  gap: 20rpx;
  padding: 20rpx 0;
  box-sizing: border-box;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  box-sizing: border-box;
}

.reset-btn {
  background: #FFFFFF;
  color: #666;
  border: 2rpx solid #E0E0E0;
}

.submit-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}

.submit-btn[disabled] {
  background: #C8E6C9;
  color: rgba(255, 255, 255, 0.7);
  box-shadow: none;
}

.reset-btn[disabled] {
  opacity: 0.5;
}
