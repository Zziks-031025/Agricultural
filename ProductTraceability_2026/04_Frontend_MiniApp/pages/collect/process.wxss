.collect-container {
  padding-bottom: 120rpx;
}

.form-card {
  margin: 20rpx;
}

.form-section {
  margin-bottom: 40rpx;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 24rpx;
  padding-left: 12rpx;
  border-left: 6rpx solid #2C7A3E;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item.half {
  width: 48%;
  display: inline-block;
}

.form-row {
  display: flex;
  justify-content: space-between;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
}

.form-label.required::before {
  content: '*';
  color: #D32F2F;
  margin-right: 4rpx;
}

.form-value {
  font-size: 28rpx;
  color: #333333;
  padding: 16rpx 0;
}

.form-input-group {
  display: flex;
  align-items: center;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  overflow: hidden;
}

.form-input {
  flex: 1;
  padding: 20rpx;
  font-size: 28rpx;
  color: #333333;
}

.scan-btn {
  width: 80rpx;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: #2C7A3E;
}

.scan-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.form-picker {
  padding: 20rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
}

.form-textarea {
  width: 100%;
  min-height: 200rpx;
  padding: 20rpx;
  border: 1rpx solid #E0E0E0;
  border-radius: 8rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #999999;
  margin-top: 8rpx;
}

.image-upload {
  margin-top: 16rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.image-item .image {
  width: 100%;
  height: 100%;
  border-radius: 8rpx;
}

.image-delete {
  position: absolute;
  top: -8rpx;
  right: -8rpx;
  width: 40rpx;
  height: 40rpx;
  background-color: #D32F2F;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #CCCCCC;
  border-radius: 8rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999999;
}

.image-add .icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.image-add .text {
  font-size: 24rpx;
}

.image-tip {
  font-size: 24rpx;
  color: #999999;
  margin-top: 12rpx;
}

.location-info {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx;
  background-color: #F5F5F5;
  border-radius: 8rpx;
}

.location-text {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
}

.location-text .icon {
  margin-right: 8rpx;
}

.location-btn {
  padding: 12rpx 24rpx;
  background-color: #FFFFFF;
  border: 1rpx solid #2C7A3E;
  color: #2C7A3E;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.location-btn.primary {
  background-color: #2C7A3E;
  color: #FFFFFF;
  border: none;
}

.location-empty {
  text-align: center;
  padding: 40rpx 0;
}

.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx;
  background-color: #FFFFFF;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  background-color: #2C7A3E;
  color: #FFFFFF;
  border-radius: 8rpx;
  font-size: 32rpx;
  font-weight: 500;
  line-height: 88rpx;
  text-align: center;
}

.submit-btn[disabled] {
  background-color: #E0E0E0;
  color: #999999;
}

.blockchain-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.modal-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background-color: rgba(0, 0, 0, 0.6);
}

.modal-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background-color: #FFFFFF;
  border-radius: 16rpx;
  padding: 48rpx 32rpx;
  text-align: center;
}

.modal-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: #FFFFFF;
}

.modal-icon.success {
  background-color: #2C7A3E;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 16rpx;
}

.modal-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

.modal-hash {
  background-color: #F5F5F5;
  padding: 24rpx;
  border-radius: 8rpx;
  margin-bottom: 32rpx;
}

.hash-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.hash-value {
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
  font-family: monospace;
}

.modal-actions {
  display: flex;
  gap: 16rpx;
}

.modal-btn {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  background-color: #F5F5F5;
  color: #666666;
  border-radius: 8rpx;
  font-size: 28rpx;
}

.modal-btn.primary {
  background-color: #2C7A3E;
  color: #FFFFFF;
}
