/* 记录详情页样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 200rpx;
  box-sizing: border-box;
}

/* 记录头部 */
.record-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #FFFFFF;
}

.type-badge {
  padding: 12rpx 32rpx;
  border-radius: 24rpx;
  font-size: 28rpx;
  font-weight: 600;
  background: rgba(255, 255, 255, 0.2);
}

.type-badge.feeding {
  background: rgba(255, 152, 0, 0.3);
}

.type-badge.vaccine {
  background: rgba(33, 150, 243, 0.3);
}

.type-badge.inspect {
  background: rgba(156, 39, 176, 0.3);
}

.type-badge.fertilize {
  background: rgba(76, 175, 80, 0.3);
}

.type-badge.irrigate {
  background: rgba(0, 188, 212, 0.3);
}

.type-badge.pesticide {
  background: rgba(244, 67, 54, 0.3);
}

.record-time {
  font-size: 26rpx;
  opacity: 0.9;
}

/* 信息卡片 */
.info-card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

/* 信息列表 */
.info-list {
  padding: 0 8rpx;
}

.info-item {
  display: flex;
  align-items: flex-start;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #F5F5F5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.info-value {
  flex: 1;
  font-size: 28rpx;
  color: #333333;
  word-break: break-all;
}

.info-value.highlight {
  color: #4CAF50;
  font-weight: 500;
}

/* 操作说明 */
.description-content {
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #666666;
  line-height: 1.8;
}

/* 照片网格 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: 12rpx;
  background: #F5F5F5;
}

/* 地理位置 */
.location-section {
  overflow: hidden;
  border-radius: 12rpx;
}

.location-map {
  width: 100%;
  height: 300rpx;
  background: #E8F5E9;
}

.map {
  width: 100%;
  height: 100%;
}

.location-info {
  padding: 20rpx;
  background: #F8F9FA;
}

.coords-row {
  display: flex;
  gap: 32rpx;
  margin-bottom: 16rpx;
}

.coord-item {
  flex: 1;
}

.coord-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 4rpx;
}

.coord-value {
  font-size: 26rpx;
  color: #333333;
  font-family: 'Courier New', monospace;
}

.address-row {
  display: flex;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #EEEEEE;
}

.address-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.address-text {
  font-size: 26rpx;
  color: #666666;
  flex: 1;
}

/* 区块链验证卡片 */
.blockchain-card {
  margin: 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.blockchain-header {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: linear-gradient(135deg, #E3F2FD 0%, #BBDEFB 100%);
}

.blockchain-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.blockchain-title {
  display: flex;
  align-items: center;
  flex: 1;
}

.title-text {
  font-size: 30rpx;
  font-weight: 600;
  color: #1565C0;
}

.title-badge {
  margin-left: 12rpx;
  padding: 4rpx 16rpx;
  background: #4CAF50;
  color: #FFFFFF;
  font-size: 22rpx;
  border-radius: 16rpx;
}

.blockchain-body {
  padding: 24rpx;
}

.chain-item {
  margin-bottom: 20rpx;
}

.chain-item:last-child {
  margin-bottom: 0;
}

.chain-label {
  font-size: 24rpx;
  color: #999999;
  display: block;
  margin-bottom: 8rpx;
}

.chain-value {
  font-size: 26rpx;
  color: #333333;
}

.chain-value.hash {
  font-family: 'Courier New', monospace;
  font-size: 22rpx;
  word-break: break-all;
  line-height: 1.6;
  color: #1565C0;
}

.chain-value-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
}

.chain-value-row .chain-value {
  flex: 1;
  min-width: 0;
}

.copy-btn {
  padding: 8rpx 20rpx;
  background: #E3F2FD;
  color: #1565C0;
  font-size: 22rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 验真部分 */
.verify-section {
  padding: 24rpx;
  border-top: 1rpx solid #F0F0F0;
}

.verify-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 88rpx;
  background: linear-gradient(135deg, #2196F3 0%, #1565C0 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.verify-btn::after {
  border: none;
}

.verify-btn.success {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
}

.verify-btn.fail {
  background: linear-gradient(135deg, #F44336 0%, #C62828 100%);
}

.verify-btn[disabled] {
  opacity: 0.8;
}

.verify-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 12rpx;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.3);
  border-top-color: #FFFFFF;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-right: 12rpx;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.verify-result {
  display: flex;
  align-items: center;
  margin-top: 20rpx;
  padding: 20rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
}

.result-icon {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.result-icon.success {
  background: #4CAF50;
}

.result-icon.fail {
  background: #F44336;
}

.result-text {
  flex: 1;
}

.result-title {
  font-size: 28rpx;
  font-weight: 600;
  display: block;
  margin-bottom: 4rpx;
}

.result-title.success {
  color: #2E7D32;
}

.result-title.fail {
  color: #C62828;
}

.result-desc {
  font-size: 24rpx;
  color: #666666;
}

/* 未上链提示 */
.pending-card {
  margin: 24rpx;
  padding: 48rpx 32rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
}

.pending-icon {
  width: 80rpx;
  height: 80rpx;
  margin-bottom: 20rpx;
  opacity: 0.5;
}

.pending-text {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.pending-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #999999;
  margin-bottom: 8rpx;
}

.pending-desc {
  font-size: 26rpx;
  color: #BDBDBD;
}

/* 底部操作 */
.footer-action {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
}

.cert-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 500;
  border: none;
  padding: 0;
  margin: 0;
}

.cert-btn::after {
  border: none;
}

.cert-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
}
