/* 添加生长记录页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: 320rpx;
  box-sizing: border-box;
}

/* 批次信息卡片 */
.batch-info-card {
  margin: 24rpx;
  padding: 32rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 16rpx;
  color: #FFFFFF;
}

.batch-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.batch-code {
  font-size: 36rpx;
  font-weight: bold;
  letter-spacing: 2rpx;
}

.product-tag {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  background: rgba(255, 255, 255, 0.2);
}

.product-tag.chicken {
  background: rgba(255, 193, 7, 0.3);
}

.product-tag.tomato {
  background: rgba(244, 67, 54, 0.3);
}

.batch-meta {
  display: flex;
  align-items: center;
  font-size: 26rpx;
  opacity: 0.9;
}

.meta-divider {
  margin: 0 16rpx;
  opacity: 0.5;
}

/* 表单卡片 */
.form-card {
  margin: 0 24rpx;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  box-sizing: border-box;
  width: calc(100% - 48rpx);
  overflow: hidden;
}

.form-section {
  margin-bottom: 40rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-section:last-child {
  margin-bottom: 0;
}

.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 20rpx;
  padding-left: 16rpx;
  border-left: 6rpx solid #4CAF50;
}

.section-subtitle {
  font-size: 24rpx;
  color: #999999;
  margin-top: -12rpx;
  margin-bottom: 20rpx;
  padding-left: 22rpx;
}

/* 记录类型横向标签 */
.record-type-tabs {
  display: flex;
  gap: 16rpx;
}

.type-tab {
  flex: 1;
  height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #F5F5F5;
  border-radius: 40rpx;
  font-size: 28rpx;
  color: #666666;
  border: 2rpx solid transparent;
  transition: all 0.3s;
}

.type-tab.active {
  background: #E8F5E9;
  border-color: #4CAF50;
  color: #2E7D32;
  font-weight: 500;
}

/* 表单项 */
.form-item {
  margin-bottom: 28rpx;
  width: 100%;
  box-sizing: border-box;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label.required::before {
  content: '*';
  color: #F44336;
  margin-right: 4rpx;
}

.form-input {
  width: 100%;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  border: none;
}

.input-with-unit {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  border-radius: 12rpx;
  overflow: hidden;
  width: 100%;
  box-sizing: border-box;
}

.input-with-unit .form-input {
  flex: 1;
  min-width: 0;
  background: transparent;
  padding-right: 0;
}

.input-with-unit .unit {
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #999999;
  flex-shrink: 0;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  padding: 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  border: none;
}

.char-count {
  text-align: right;
  font-size: 24rpx;
  color: #BDBDBD;
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  width: 100%;
}

.form-picker .placeholder {
  color: #BDBDBD;
}

.picker-arrow {
  color: #BDBDBD;
  font-size: 28rpx;
  flex-shrink: 0;
}

/* 图片上传 */
.image-upload {
  margin-top: 16rpx;
}

.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
}

.preview-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.image-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 44rpx;
  height: 44rpx;
  background: #F44336;
  color: #FFFFFF;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: bold;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  background: #F8F9FA;
  border: 2rpx dashed #E0E0E0;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.add-icon {
  width: 56rpx;
  height: 56rpx;
  margin-bottom: 12rpx;
  opacity: 0.6;
}

.add-text {
  font-size: 24rpx;
  color: #999999;
}

.image-tip {
  font-size: 24rpx;
  color: #BDBDBD;
  margin-top: 16rpx;
}

/* 地理位置 */
.location-btn {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 20rpx 24rpx;
  display: flex;
  align-items: center;
}

.location-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.location-text {
  font-size: 28rpx;
  color: #2E7D32;
  flex: 1;
}

.location-coords-info {
  margin-top: 12rpx;
  padding: 12rpx 24rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
}

.coords-text {
  font-size: 22rpx;
  color: #999999;
}

/* 提交区域 */
.submit-section {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background-color: #FFFFFF;
  box-shadow: 0 -4rpx 20rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.blockchain-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 16rpx;
  font-size: 24rpx;
  color: #999999;
}

.tip-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 8rpx;
}

.submit-btn {
  width: 100%;
  height: 96rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #FFFFFF;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
  padding: 0;
  margin: 0;
  line-height: 96rpx;
}

.submit-btn::after {
  border: none;
}

.submit-btn[disabled] {
  background: #E0E0E0;
  color: #999999;
}

/* 加载弹窗 */
.loading-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.loading-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.loading-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 480rpx;
  padding: 60rpx 40rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  text-align: center;
}

.loading-animation {
  display: flex;
  justify-content: center;
  align-items: center;
  margin-bottom: 32rpx;
}

.loading-circle {
  width: 24rpx;
  height: 24rpx;
  background: #4CAF50;
  border-radius: 50%;
  margin: 0 12rpx;
  animation: bounce 1.4s infinite ease-in-out both;
}

.loading-circle.delay1 {
  animation-delay: 0.16s;
}

.loading-circle.delay2 {
  animation-delay: 0.32s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0);
  }
  40% {
    transform: scale(1);
  }
}

.loading-text {
  font-size: 32rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
}

.loading-step {
  font-size: 26rpx;
  color: #999999;
}

/* 成功弹窗 */
.success-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 9999;
}

.success-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
}

.success-content {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 620rpx;
  padding: 48rpx 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  text-align: center;
}

.success-icon {
  width: 120rpx;
  height: 120rpx;
  margin: 0 auto 24rpx;
}

.success-icon image {
  width: 100%;
  height: 100%;
}

.success-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 12rpx;
}

.success-desc {
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 32rpx;
}

.tx-info {
  background: #F5F5F5;
  padding: 24rpx;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.tx-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 12rpx;
}

.tx-hash {
  font-size: 24rpx;
  color: #333333;
  word-break: break-all;
  font-family: 'Courier New', monospace;
  line-height: 1.6;
}

.block-info {
  display: flex;
  justify-content: space-around;
  margin-bottom: 32rpx;
}

.block-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.block-label {
  font-size: 24rpx;
  color: #999999;
  margin-bottom: 8rpx;
}

.block-value {
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: 500;
}

.success-actions {
  display: flex;
  gap: 20rpx;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  display: flex;
  align-items: center;
  justify-content: center;
}

.action-btn.secondary {
  background: #F5F5F5;
  color: #666666;
}

.action-btn.primary {
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  color: #FFFFFF;
}
