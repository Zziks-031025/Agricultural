<view class="batch-container">
  <!-- 搜索区域 -->
  <view class="search-section">
    <view class="search-box">
      <image class="search-icon" src="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='%23999'%3E%3Cpath d='M15.5 14h-.79l-.28-.27A6.471 6.471 0 0016 9.5 6.5 6.5 0 109.5 16c1.61 0 3.09-.59 4.23-1.57l.27.28v.79l5 4.99L20.49 19l-4.99-5zm-6 0C7.01 14 5 11.99 5 9.5S7.01 5 9.5 5 14 7.01 14 9.5 11.99 14 9.5 14z'/%3E%3C/svg%3E" mode="aspectFit"></image>
      <input class="search-input" placeholder="搜索批次号/产品名称" bindinput="onSearchInput" value="{{searchKeyword}}" confirm-type="search" />
      <view class="search-clear" wx:if="{{searchKeyword}}" bindtap="clearSearch">×</view>
    </view>
  </view>

  <!-- Tabs - dynamic per role -->
  <view class="tabs-section">
    <view class="tabs-container">
      <view
        class="tab-item {{activeTab === item.key ? 'active' : ''}}"
        wx:for="{{tabList}}"
        wx:key="key"
        bindtap="switchTab"
        data-tab="{{item.key}}"
      >
        <text class="tab-text">{{item.label}}</text>
        <view class="tab-dot {{item.dotWarning ? 'warning' : ''}}" wx:if="{{item.showDot}}"></view>
      </view>
    </view>
  </view>

  <!-- 批次列表 -->
  <scroll-view class="batch-list" scroll-y bindscrolltolower="loadMore" lower-threshold="100">
    <view class="batch-card" wx:for="{{batchList}}" wx:key="id">
      <!-- 头部：产品图标 + 批次编号 + 状态标签 -->
      <view class="card-header">
        <view class="header-left">
          <view class="product-icon-wrapper">
            <image class="product-icon" src="{{item.productIcon || '/images/agricultural.png'}}" mode="aspectFit"></image>
          </view>
          <view class="batch-code-info">
            <text class="batch-code">{{item.batchCode}}</text>
            <text class="enterprise-name">{{item.enterpriseName}}</text>
          </view>
        </view>
        <view class="status-badge" style="background: {{item.statusColor}}20; color: {{item.statusColor}};">{{item.statusText}}</view>
      </view>

      <!-- 中部：3列关键信息 -->
      <view class="card-body">
        <view class="info-grid">
          <view class="info-item">
            <text class="info-label">产品名称</text>
            <text class="info-value">{{item.productName || '白羽肉鸡'}}</text>
          </view>
          <view class="info-item">
            <text class="info-label">当前数量</text>
            <text class="info-value highlight">{{item.quantity || 0}} {{item.unit || '只'}}</text>
          </view>
          <view class="info-item" wx:if="{{!isInspector}}">
            <text class="info-label">创建日期</text>
            <text class="info-value">{{item.createDate}}</text>
          </view>
          <!-- 检疫员：显示检疫结果 -->
          <view class="info-item" wx:if="{{isInspector}}">
            <text class="info-label">检疫结果</text>
            <text class="info-value" wx:if="{{item.inspectionResult === 1}}" style="color:#2E7D32;font-weight:bold;">合格</text>
            <text class="info-value" wx:elif="{{item.inspectionResult === 0}}" style="color:#C62828;font-weight:bold;">不合格</text>
            <text class="info-value" wx:else style="color:#FF9800;">待处理</text>
          </view>
        </view>
      </view>

      <!-- 底部：区块链存证 + 操作按钮 -->
      <view class="card-footer">
        <view class="footer-left">
          <view class="chain-info" wx:if="{{item.txHash}}" catchtap="copyHash" data-hash="{{item.txHash}}">
            <image class="chain-icon" src="/images/Blockchain.png" mode="aspectFit"></image>
            <text class="tx-hash-text">{{item.txHashDisplay}}</text>
            <image class="copy-icon" src="/images/copy.png" mode="aspectFit"></image>
          </view>
          <view class="no-chain-info" wx:else>
            <text class="pending-chain-text">待上链存证</text>
          </view>
        </view>
        <view class="footer-right">
          <view class="action-btn qrcode-btn" catchtap="showBatchCode" data-item="{{item}}">
            <image class="qrcode-icon" src="/images/QR-code.png" mode="aspectFit"></image>
          </view>
          <view class="action-btn detail-btn" catchtap="goToDetail" data-id="{{item.id}}">
            <text class="btn-text">详情</text>
          </view>
        </view>
      </view>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{batchList.length === 0 && !loading}}">
      <image class="empty-img" src="/images/batch-list.png" mode="aspectFit"></image>
      <text class="empty-title">暂无批次数据</text>
      <text class="empty-desc">{{activeTab === 'all' ? '暂无相关批次记录' : '当前没有"' + activeTabLabel + '"的批次'}}</text>
    </view>

    <!-- 加载状态 -->
    <view class="loading-more" wx:if="{{loading}}">
      <view class="loading-spinner"></view>
      <text class="loading-text">加载中...</text>
    </view>

    <!-- 没有更多 -->
    <view class="no-more" wx:if="{{noMore && batchList.length > 0}}">
      <text class="no-more-text">— 已加载全部 —</text>
    </view>
  </scroll-view>
</view>

<!-- 批次二维码弹窗 -->
<view class="qrcode-modal" wx:if="{{showQrcode}}" bindtap="hideQrcode">
  <view class="qrcode-content" catchtap="stopPropagation">
    <view class="qrcode-header">
      <text class="qrcode-title">批次二维码</text>
      <view class="qrcode-close" bindtap="hideQrcode">×</view>
    </view>
    <view class="qrcode-body">
      <image class="qrcode-img" src="{{currentQrcode}}" mode="aspectFit"></image>
      <text class="qrcode-batch">{{currentBatchCode}}</text>
      <text class="qrcode-tip">扫描二维码可查看批次溯源信息</text>
    </view>
    <view class="qrcode-footer">
      <view class="qrcode-save-btn" bindtap="saveQrcode">
        <text>保存到相册</text>
      </view>
    </view>
  </view>
</view>
