/* ========== 页面容器 ========== */
.batch-container {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

/* ========== 搜索区域 ========== */
.search-section {
  padding: 24rpx 30rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.search-box {
  background: #FFFFFF;
  border-radius: 40rpx;
  padding: 16rpx 24rpx;
  display: flex;
  align-items: center;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.search-icon {
  width: 36rpx;
  height: 36rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
  opacity: 0.5;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.search-clear {
  width: 40rpx;
  height: 40rpx;
  background: #E0E0E0;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: #666;
  margin-left: 12rpx;
  flex-shrink: 0;
}

/* ========== Tabs 区域 ========== */
.tabs-section {
  padding: 20rpx 30rpx;
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.tabs-container {
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 6rpx;
  display: flex;
  gap: 6rpx;
}

.tab-item {
  flex: 1;
  height: 68rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  transition: all 0.3s ease;
  position: relative;
}

.tab-text {
  font-size: 26rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab-item.active {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab-item.active .tab-text {
  color: #4CAF50;
  font-weight: bold;
}

/* Tab 状态小圆点 */
.tab-dot {
  position: absolute;
  top: 12rpx;
  right: 20rpx;
  width: 12rpx;
  height: 12rpx;
  background: #F44336;
  border-radius: 50%;
}

/* 待检疫警告小圆点 - 橙色 */
.tab-dot.warning {
  background: #FF9800;
}

/* ========== 批次列表 ========== */
.batch-list {
  flex: 1;
  padding: 20rpx 30rpx;
  box-sizing: border-box;
}

/* ========== 批次卡片 ========== */
.batch-card {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  transition: all 0.2s;
  box-sizing: border-box;
  width: 100%;
  overflow: hidden;
}

.batch-card:active {
  transform: scale(0.98);
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

/* 卡片头部 */
.card-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
  padding-bottom: 16rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.header-left {
  display: flex;
  align-items: center;
  flex: 1;
  min-width: 0;
}

.product-icon-wrapper {
  width: 72rpx;
  height: 72rpx;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  border-radius: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.product-icon {
  width: 44rpx;
  height: 44rpx;
}

.batch-code-info {
  flex: 1;
  min-width: 0;
}

.batch-code {
  display: block;
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 4rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.enterprise-name {
  display: block;
  font-size: 22rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* 状态标签 - 使用动态颜色 */
.status-badge {
  font-size: 22rpx;
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-weight: 500;
  flex-shrink: 0;
  margin-left: 12rpx;
  white-space: nowrap;
}

/* 卡片中部 - 3列信息 */
.card-body {
  margin-bottom: 16rpx;
}

.info-grid {
  display: flex;
  justify-content: space-between;
  background: #FAFAFA;
  border-radius: 12rpx;
  padding: 16rpx 12rpx;
}

.info-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  position: relative;
}

.info-item:not(:last-child)::after {
  content: '';
  position: absolute;
  right: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 1rpx;
  height: 50rpx;
  background: #E0E0E0;
}

.info-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.info-value {
  font-size: 26rpx;
  color: #333;
  font-weight: 500;
}

.info-value.highlight {
  color: #4CAF50;
  font-weight: bold;
}

/* 卡片底部 */
.card-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding-top: 16rpx;
  border-top: 1rpx solid #F0F0F0;
}

.footer-left {
  flex: 1;
  min-width: 0;
}

.chain-info {
  display: flex;
  align-items: center;
  background: #F8F9FA;
  padding: 10rpx 14rpx;
  border-radius: 8rpx;
  max-width: fit-content;
}

.chain-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.tx-hash-text {
  font-size: 22rpx;
  color: #888;
  font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
  margin-right: 8rpx;
}

.copy-icon {
  width: 24rpx;
  height: 24rpx;
  opacity: 0.6;
  flex-shrink: 0;
}

.no-chain-info {
  display: flex;
  align-items: center;
}

.pending-chain-text {
  font-size: 22rpx;
  color: #BDBDBD;
}

.footer-right {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.action-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  transition: all 0.2s;
}

.action-btn:active {
  opacity: 0.7;
}

.qrcode-btn {
  height: 64rpx;
  padding: 0 12rpx;
  background: transparent;
}

.qrcode-icon {
  width: 44rpx;
  height: 44rpx;
}

.detail-btn {
  height: 64rpx;
  padding: 0 24rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
}

.btn-text {
  font-size: 24rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 100rpx 48rpx;
}

.empty-img {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-title {
  font-size: 32rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.empty-desc {
  font-size: 26rpx;
  color: #999;
  text-align: center;
}

/* ========== 加载状态 ========== */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 30rpx 0;
}

.loading-spinner {
  width: 36rpx;
  height: 36rpx;
  border: 4rpx solid #E0E0E0;
  border-top-color: #4CAF50;
  border-radius: 50%;
  margin-right: 12rpx;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

.no-more {
  text-align: center;
  padding: 30rpx 0;
}

.no-more-text {
  font-size: 24rpx;
  color: #BDBDBD;
}

/* ========== 二维码弹窗 ========== */
.qrcode-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.qrcode-content {
  width: 560rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  overflow: hidden;
  animation: scaleIn 0.3s ease;
}

@keyframes scaleIn {
  from { transform: scale(0.9); opacity: 0; }
  to { transform: scale(1); opacity: 1; }
}

.qrcode-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 28rpx 32rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.qrcode-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.qrcode-close {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #999;
}

.qrcode-body {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 40rpx;
}

.qrcode-img {
  width: 320rpx;
  height: 320rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #F0F0F0;
  border-radius: 12rpx;
}

.qrcode-batch {
  font-size: 28rpx;
  font-weight: 500;
  color: #333;
  margin-bottom: 12rpx;
}

.qrcode-tip {
  font-size: 24rpx;
  color: #999;
}

.qrcode-footer {
  padding: 24rpx 32rpx 32rpx;
}

.qrcode-save-btn {
  height: 88rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #FFFFFF;
  font-size: 30rpx;
  font-weight: 500;
}
