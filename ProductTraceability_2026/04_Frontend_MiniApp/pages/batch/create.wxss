.create-container {
  min-height: 100vh;
  background: #F1F8E9;
  padding-bottom: calc(200rpx + env(safe-area-inset-bottom));
}

.template-tabs {
  padding: 30rpx;
  display: flex;
  justify-content: center;
}

.tabs-container {
  width: 90%;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 6rpx;
  display: flex;
  gap: 6rpx;
}

.tab-item {
  flex: 1;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 8rpx;
  transition: all 0.3s;
}

.tab-text {
  font-size: 28rpx;
  color: #666666;
  transition: all 0.3s;
}

.tab-item.active {
  background: #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.tab-item.active .tab-text {
  color: #2E7D32;
  font-weight: bold;
}

.form-section {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 30rpx;
  margin: 20rpx 30rpx 0;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #2E7D32;
  margin-bottom: 24rpx;
  padding-bottom: 16rpx;
  border-bottom: 2rpx solid #E8F5E9;
}

.form-item {
  margin-bottom: 24rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 12rpx;
  display: block;
}

.form-label.required::before {
  content: '*';
  color: #FF5252;
  margin-right: 4rpx;
}

.form-value {
  background: #E8F5E9;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #2E7D32;
  font-weight: bold;
}

.form-hint {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

.form-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
  background: #F8F9FA;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #333333;
  box-sizing: border-box;
  width: 100%;
}

.form-picker .placeholder {
  color: #BDBDBD;
}

.picker-arrow {
  color: #BDBDBD;
  font-size: 28rpx;
  flex-shrink: 0;
}

.form-input {
  background: #F5F5F5;
  border-radius: 8rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: #333;
}

.location-btn {
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 100%);
  border: 2rpx solid #4CAF50;
  border-radius: 8rpx;
  padding: 24rpx;
  display: flex;
  align-items: center;
}

.location-icon {
  width: 40rpx;
  height: 40rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.location-text {
  font-size: 28rpx;
  color: #2E7D32;
  flex: 1;
}

.form-actions {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  padding: 20rpx 30rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  display: flex;
  gap: 20rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.08);
  z-index: 100;
}

.action-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: bold;
  display: flex;
  align-items: center;
  justify-content: center;
  border: none;
}

.reset-btn {
  background: #FFFFFF;
  color: #666;
  border: 2rpx solid #E0E0E0;
}

.submit-btn {
  background: linear-gradient(135deg, #66BB6A 0%, #4CAF50 100%);
  color: #FFFFFF;
  box-shadow: 0 4rpx 12rpx rgba(76, 175, 80, 0.3);
}
