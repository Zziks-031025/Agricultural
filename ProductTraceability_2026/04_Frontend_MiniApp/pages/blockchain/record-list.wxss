/* 区块链上链记录流水页样式 */
.record-list-page {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: env(safe-area-inset-bottom);
}

/* ========== 顶部统计卡片 ========== */
.stats-card {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  padding: 40rpx 30rpx;
  margin-bottom: 20rpx;
}

.stats-header {
  margin-bottom: 30rpx;
}

.stats-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
}

.stats-enterprise {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-grid {
  display: flex;
  align-items: center;
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  padding: 30rpx 0;
}

.stats-item {
  flex: 1;
  text-align: center;
}

.stats-value {
  font-size: 48rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 8rpx;
  font-family: 'DIN Alternate', 'Arial', sans-serif;
}

.stats-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.3);
}

/* ========== 记录列表区域 ========== */
.record-section {
  padding: 0 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
}

.section-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.section-tip {
  font-size: 24rpx;
  color: #999;
}

/* ========== 记录列表 ========== */
.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  transition: all 0.2s;
}

.record-item:active {
  transform: scale(0.98);
  background: #FAFAFA;
}

/* 中间内容 */
.record-content {
  flex: 1;
  min-width: 0;
}

.record-main {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.record-type {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

.record-batch {
  font-size: 22rpx;
  color: #4CAF50;
  background: #E8F5E9;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
}

.record-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.record-time {
  font-size: 24rpx;
  color: #999;
}

.record-operator {
  font-size: 24rpx;
  color: #999;
}

.record-hash {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 8rpx 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  margin-top: 4rpx;
}

.hash-label {
  font-size: 22rpx;
  color: #999;
}

.hash-value {
  font-size: 22rpx;
  color: #1976D2;
  font-family: 'SF Mono', 'Consolas', monospace;
}

.copy-hint {
  font-size: 20rpx;
  color: #4CAF50;
  margin-left: auto;
}

/* 右侧箭头 */
.record-arrow {
  margin-left: 16rpx;
  flex-shrink: 0;
}

.arrow-icon {
  font-size: 40rpx;
  color: #BDBDBD;
}

/* ========== 加载状态 ========== */
.loading-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 16rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  background: #4CAF50;
  border-radius: 50%;
  animation: bounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) {
  animation-delay: 0s;
}

.dot:nth-child(2) {
  animation-delay: 0.16s;
}

.dot:nth-child(3) {
  animation-delay: 0.32s;
}

@keyframes bounce {
  0%, 80%, 100% {
    transform: scale(0.6);
    opacity: 0.5;
  }
  40% {
    transform: scale(1);
    opacity: 1;
  }
}

.loading-text {
  font-size: 26rpx;
  color: #999;
}

/* ========== 没有更多 ========== */
.no-more {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 40rpx 0;
  gap: 20rpx;
}

.no-more-line {
  width: 80rpx;
  height: 1rpx;
  background: #E0E0E0;
}

.no-more-text {
  font-size: 24rpx;
  color: #BDBDBD;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
  opacity: 0.6;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-tip {
  font-size: 26rpx;
  color: #999;
}
