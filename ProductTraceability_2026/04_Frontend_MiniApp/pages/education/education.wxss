.education-container {
  min-height: 100vh;
  background: #F5F5F5;
}

/* ========== 文章列表视图 ========== */
.list-view {
  padding-bottom: 40rpx;
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  background: #FFFFFF;
  margin-bottom: 20rpx;
}

.list-title {
  font-size: 36rpx;
  font-weight: bold;
  color: #2E7D32;
}

.list-count {
  font-size: 24rpx;
  color: #999;
}

/* 文章卡片列表 */
.article-list {
  padding: 0 24rpx;
}

.article-card {
  display: flex;
  background: #FFFFFF;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.card-cover {
  width: 240rpx;
  height: 200rpx;
  flex-shrink: 0;
}

.card-content {
  flex: 1;
  padding: 20rpx 24rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  min-width: 0;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  line-height: 1.4;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.card-summary {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin: 8rpx 0;
}

.card-meta {
  display: flex;
  align-items: center;
  font-size: 22rpx;
  color: #999;
}

.meta-author {
  color: #4CAF50;
}

.meta-dot {
  margin: 0 8rpx;
}

.meta-date,
.meta-views {
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.5;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 文章详情视图 ========== */
.detail-view {
  padding-bottom: 120rpx;
}

/* 返回栏 */
.back-bar {
  display: flex;
  align-items: center;
  padding: 24rpx 32rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.back-icon {
  font-size: 36rpx;
  color: #4CAF50;
  margin-right: 12rpx;
}

.back-text {
  font-size: 28rpx;
  color: #4CAF50;
}

.article-header {
  background: #fff;
  padding: 40rpx 32rpx;
  margin-bottom: 20rpx;
}

.article-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
  line-height: 1.5;
  margin-bottom: 24rpx;
}

.article-meta {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  font-size: 24rpx;
}

.meta-label {
  color: #999;
  margin-right: 8rpx;
}

.meta-value {
  color: #666;
}

.article-content {
  background: #fff;
  padding: 32rpx;
}

.content-section {
  margin-bottom: 32rpx;
}

.content-section:last-child {
  margin-bottom: 0;
}

.content-text {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  text-align: justify;
  display: block;
}

.content-subtitle {
  font-size: 34rpx;
  font-weight: bold;
  color: #2E7D32;
  line-height: 1.6;
  display: block;
  padding-left: 16rpx;
  border-left: 6rpx solid #2E7D32;
}

.content-image {
  width: 100%;
  border-radius: 12rpx;
  display: block;
}

.article-footer {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 32rpx;
  padding-bottom: calc(20rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: #fff;
  box-shadow: 0 -4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.share-btn {
  width: 100%;
  height: 88rpx;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  border-radius: 44rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(46, 125, 50, 0.4);
  border: none;
  padding: 0;
}

.share-btn::after {
  border: none;
}

.share-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #fff;
}
