/* ========== 页面基础 ========== */
.trace-page {
  width: 100%;
  min-height: 100vh;
  background: #F8F8F8;
  position: relative;
}

.main-content {
  width: 100%;
  height: 100vh;
}

/* ========== 加载状态 ========== */
.loading-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  background: #F8F8F8;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid #E8F5E9;
  border-top-color: #4CAF50;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.loading-text {
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #666;
}

/* ========== 头部产品大图 ========== */
.header-section {
  position: relative;
  width: 100%;
  height: 450rpx;
  overflow: hidden;
}

.product-banner {
  width: 100%;
  height: 100%;
}

.product-banner-placeholder {
  width: 100%;
  height: 100%;
  background: linear-gradient(135deg, #E8F5E9 0%, #C8E6C9 100%);
  display: flex;
  align-items: center;
  justify-content: center;
}

.placeholder-text {
  font-size: 28rpx;
  color: #81C784;
}

.header-gradient {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 150rpx;
  background: linear-gradient(to top, rgba(248, 248, 248, 1) 0%, transparent 100%);
}

/* 区块链徽章 */
.blockchain-badge {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  align-items: center;
  padding: 12rpx 20rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 30rpx;
  box-shadow: 0 4rpx 16rpx rgba(76, 175, 80, 0.4);
}

.badge-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.badge-text {
  font-size: 22rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* ========== 产品信息卡片 ========== */
.product-card {
  margin: -60rpx 24rpx 24rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
  position: relative;
  z-index: 10;
}

.card-header {
  margin-bottom: 28rpx;
  padding-bottom: 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.product-name {
  display: block;
  font-size: 42rpx;
  font-weight: bold;
  color: #1A1A1A;
  margin-bottom: 12rpx;
}

.batch-code {
  display: block;
  font-size: 26rpx;
  color: #999;
}

/* 参数网格 */
.params-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 24rpx;
}

.param-item {
  display: flex;
  flex-direction: column;
}

.param-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.param-value {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-tag.active {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-tag.processing {
  background: #E3F2FD;
  color: #2196F3;
}

.status-tag.completed {
  background: #FFF3E0;
  color: #FF9800;
}

/* ========== 时间轴区域 ========== */
.timeline-section {
  margin: 24rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
}

.section-header {
  display: flex;
  align-items: center;
  margin-bottom: 32rpx;
}

.section-icon {
  width: 48rpx;
  height: 48rpx;
  margin-right: 16rpx;
}

.section-icon image {
  width: 100%;
  height: 100%;
}

.section-title {
  font-size: 34rpx;
  font-weight: bold;
  color: #1A1A1A;
}

/* 时间轴容器 */
.timeline-container {
  padding-left: 8rpx;
}

.timeline-item {
  display: flex;
  position: relative;
  padding-bottom: 40rpx;
}

.timeline-item.last {
  padding-bottom: 0;
}

/* 时间轴左侧 */
.timeline-left {
  display: flex;
  flex-direction: column;
  align-items: center;
  width: 40rpx;
  margin-right: 24rpx;
}

.timeline-dot {
  width: 24rpx;
  height: 24rpx;
  border-radius: 50%;
  background: #E0E0E0;
  border: 4rpx solid #FFFFFF;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
  z-index: 2;
  flex-shrink: 0;
}

.timeline-dot.active {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  width: 28rpx;
  height: 28rpx;
}

/* 检疫节点圆点 - 使用系统绿色 */
.timeline-dot.quarantine-dot {
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  width: 28rpx;
  height: 28rpx;
  box-shadow: 0 2rpx 12rpx rgba(46, 125, 50, 0.3);
}

.timeline-line {
  width: 4rpx;
  flex: 1;
  background: linear-gradient(to bottom, #E0E0E0 0%, #F5F5F5 100%);
  margin-top: 8rpx;
}

/* 时间轴内容区 */
.timeline-content {
  flex: 1;
  background: #FAFAFA;
  border-radius: 16rpx;
  padding: 24rpx;
  border-left: 4rpx solid #E8F5E9;
}

.timeline-item.first .timeline-content {
  border-left-color: #4CAF50;
  background: linear-gradient(135deg, #F1F8E9 0%, #FAFAFA 100%);
}

/* 检疫节点内容区 - 强化视觉 */
.quarantine-content {
  border-left-color: #2E7D32 !important;
  background: linear-gradient(135deg, #E8F5E9 0%, #F1F8E9 50%, #FAFAFA 100%) !important;
}

.content-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.header-left {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 10rpx;
}

.process-name {
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
}

/* 节点来源标签 */
.node-type-tag {
  display: inline-block;
  font-size: 20rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

.tag-breeding {
  background: #E8F5E9;
  color: #2E7D32;
}

.tag-quarantine {
  background: #E8F5E9;
  color: #1B5E20;
  border: 1rpx solid #A5D6A7;
}

.tag-processing {
  background: #E3F2FD;
  color: #1565C0;
}

.tag-storage {
  background: #FFF3E0;
  color: #E65100;
}

.tag-transport {
  background: #F3E5F5;
  color: #7B1FA2;
}

.tag-sales {
  background: #FFF8E1;
  color: #F57F17;
}

.process-time {
  font-size: 24rpx;
  color: #999;
  flex-shrink: 0;
}

.content-body {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

/* 详情列表容器 */
.details-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.info-row {
  display: flex;
  align-items: center;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  margin-right: 12rpx;
  min-width: 140rpx;
  flex-shrink: 0;
}

.info-value {
  font-size: 26rpx;
  color: #666;
  flex: 1;
  word-break: break-all;
}

/* 检疫结果值样式 */
.info-value.result-pass {
  color: #2E7D32;
  font-weight: 600;
}

.info-value.result-fail {
  color: #C62828;
  font-weight: 600;
}

.location-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
}

.location-text {
  color: #4CAF50;
}

.info-row.remark {
  margin-top: 8rpx;
}

.remark-text {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
}

/* ========== 检疫节点专属样式 ========== */

/* 检疫结果行 */
.quarantine-result-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 8rpx;
}

/* 检疫结果标签 */
.result-tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 20rpx;
  border-radius: 8rpx;
  font-weight: 600;
}

.result-tag.result-pass {
  background: #E8F5E9;
  border: 1rpx solid #A5D6A7;
}

.result-tag.result-pass .result-tag-text {
  color: #2E7D32;
  font-size: 26rpx;
}

.result-tag.result-fail {
  background: #FFEBEE;
  border: 1rpx solid #EF9A9A;
}

.result-tag.result-fail .result-tag-text {
  color: #C62828;
  font-size: 26rpx;
}

/* 官方背书标签 */
.official-label {
  font-size: 22rpx;
  color: #1B5E20;
  background: linear-gradient(135deg, #C8E6C9 0%, #A5D6A7 100%);
  padding: 6rpx 14rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 检疫员名称 */
.quarantine-inspector {
  color: #2E7D32;
  font-weight: 500;
}

/* 检疫证书缩略图 */
.certificate-preview {
  margin-top: 16rpx;
}

.cert-thumb-wrap {
  position: relative;
  display: inline-block;
  width: 240rpx;
  height: 160rpx;
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.1);
}

.cert-thumb {
  width: 100%;
  height: 100%;
}

.cert-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 50rpx;
  background: linear-gradient(to top, rgba(0, 0, 0, 0.5) 0%, transparent 100%);
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding-bottom: 8rpx;
}

.cert-overlay-text {
  font-size: 20rpx;
  color: #FFFFFF;
}

.cert-badge {
  position: absolute;
  top: 8rpx;
  left: 8rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.cert-badge-text {
  font-size: 18rpx;
  color: #FFFFFF;
  font-weight: 500;
}

/* 照片列表 */
.photo-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
}

.photo-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  object-fit: cover;
}

/* 哈希值外显 */
.tx-hash-preview {
  margin-top: 12rpx;
  padding: 8rpx 12rpx;
  background: #F5F5F5;
  border-radius: 8rpx;
  display: inline-flex;
  align-items: center;
  gap: 10rpx;
}

.tx-hash-text {
  font-size: 22rpx;
  color: #888;
  font-family: 'SF Mono', 'Consolas', 'Monaco', monospace;
  letter-spacing: 0.5rpx;
}

/* 官方背书哈希标识 */
.official-hash-badge {
  font-size: 18rpx;
  color: #FFFFFF;
  background: linear-gradient(135deg, #2E7D32 0%, #4CAF50 100%);
  padding: 4rpx 10rpx;
  border-radius: 6rpx;
  font-weight: 500;
}

/* 区块链存证信息 */
.chain-info {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx dashed #E8E8E8;
}

.chain-toggle {
  display: flex;
  align-items: center;
  padding: 8rpx 0;
}

.chain-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 10rpx;
}

.chain-label {
  font-size: 26rpx;
  color: #4CAF50;
  font-weight: 500;
  flex: 1;
}

.toggle-arrow {
  font-size: 24rpx;
  color: #999;
  transition: transform 0.3s ease;
}

.toggle-arrow.expanded {
  transform: rotate(90deg);
}

.chain-detail {
  max-height: 0;
  overflow: hidden;
  transition: max-height 0.3s ease, padding 0.3s ease;
}

.chain-detail.show {
  max-height: 300rpx;
  padding: 16rpx 0;
}

.chain-row {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.chain-row:last-child {
  margin-bottom: 0;
}

.chain-key {
  font-size: 24rpx;
  color: #999;
  width: 120rpx;
}

.chain-value {
  font-size: 24rpx;
  color: #666;
  flex: 1;
  word-break: break-all;
}

/* 官方背书文字 */
.official-value {
  color: #2E7D32;
  font-weight: 500;
}

.copy-icon {
  width: 28rpx;
  height: 28rpx;
  margin-left: 12rpx;
  opacity: 0.6;
}

/* 空状态 */
.empty-timeline {
  padding: 60rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

/* ========== 企业信息 ========== */
.enterprise-section {
  margin: 24rpx;
  padding: 32rpx;
  background: #FFFFFF;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 20rpx rgba(0, 0, 0, 0.05);
}

.enterprise-card {
  display: flex;
  align-items: center;
  padding: 20rpx;
  background: #FAFAFA;
  border-radius: 16rpx;
  transition: background 0.15s ease;
}

.enterprise-card.card-hover {
  background: #F0F0F0;
}

.enterprise-logo {
  width: 88rpx;
  height: 88rpx;
  border-radius: 16rpx;
  margin-right: 20rpx;
  background: #FFFFFF;
}

.enterprise-info {
  flex: 1;
}

.enterprise-name {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 8rpx;
}

.verify-status {
  display: flex;
  align-items: center;
}

.verify-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #4CAF50;
  margin-right: 8rpx;
}

.verify-text {
  font-size: 24rpx;
  color: #4CAF50;
}

.enterprise-arrow {
  font-size: 32rpx;
  color: #CCC;
}

/* 企业详细信息 */
.enterprise-detail {
  margin-top: 20rpx;
  padding-top: 20rpx;
  border-top: 1rpx solid #F0F0F0;
}

.enterprise-detail .detail-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
}

.enterprise-detail .detail-label {
  font-size: 26rpx;
  color: #999;
}

.enterprise-detail .detail-value {
  font-size: 26rpx;
  color: #333;
  font-family: 'SF Mono', 'Consolas', monospace;
}

/* 底部留白 */
.bottom-space {
  height: 40rpx;
}

/* ========== 错误状态 ========== */
.error-container {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  height: 100vh;
  padding: 60rpx;
}

.error-icon {
  width: 160rpx;
  height: 160rpx;
  opacity: 0.5;
  margin-bottom: 30rpx;
}

.error-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 40rpx;
  text-align: center;
}

.retry-btn {
  padding: 20rpx 60rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
  border-radius: 40rpx;
  color: #FFFFFF;
  font-size: 30rpx;
}

/* ========== 固定底部按钮 ========== */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 20rpx 40rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  background: linear-gradient(to top, #FFFFFF 80%, transparent 100%);
  z-index: 100;
}

.verify-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 100rpx;
  background: linear-gradient(135deg, #4CAF50 0%, #2E7D32 100%);
  border-radius: 50rpx;
  box-shadow: 0 8rpx 24rpx rgba(76, 175, 80, 0.4);
}

.verify-btn .btn-icon {
  width: 44rpx;
  height: 44rpx;
  margin-right: 16rpx;
}

.verify-btn .btn-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #FFFFFF;
  letter-spacing: 4rpx;
}

.btn-hover {
  opacity: 0.9;
  transform: scale(0.98);
}

/* ========== 验真 Loading ========== */
.verify-loading {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.85);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.verify-loading-content {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.loading-animation {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 40rpx;
}

.pulse-ring {
  position: absolute;
  width: 100%;
  height: 100%;
  border: 4rpx solid #4CAF50;
  border-radius: 50%;
  animation: pulse 2s ease-out infinite;
}

.pulse-ring.delay-1 {
  animation-delay: 0.5s;
}

.pulse-ring.delay-2 {
  animation-delay: 1s;
}

@keyframes pulse {
  0% {
    transform: scale(0.5);
    opacity: 1;
  }
  100% {
    transform: scale(1.5);
    opacity: 0;
  }
}

.loading-center-dot {
  width: 24rpx;
  height: 24rpx;
  background: #4CAF50;
  border-radius: 50%;
  z-index: 2;
}

.loading-title {
  font-size: 36rpx;
  color: #FFFFFF;
  font-weight: 600;
  margin-bottom: 16rpx;
}

.loading-desc {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}

/* ========== 验真结果弹窗 ========== */
.verify-result-modal {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 1000;
  animation: fadeIn 0.3s ease;
}

.result-content {
  width: 600rpx;
  background: #FFFFFF;
  border-radius: 32rpx;
  padding: 60rpx 40rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  animation: scaleIn 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
}

@keyframes scaleIn {
  from {
    opacity: 0;
    transform: scale(0.8) translateY(30rpx);
  }
  to {
    opacity: 1;
    transform: scale(1) translateY(0);
  }
}

.result-icon-wrapper {
  position: relative;
  margin-bottom: 32rpx;
}

.result-icon {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  z-index: 2;
}

.success-icon {
  background: linear-gradient(135deg, #4CAF50 0%, #8BC34A 100%);
}

.failed-icon {
  background: linear-gradient(135deg, #F44336 0%, #E91E63 100%);
}

.icon-check, .icon-warning {
  font-size: 60rpx;
  color: #FFFFFF;
  font-weight: bold;
}

.icon-glow {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  z-index: 1;
  animation: glowPulse 2s ease-in-out infinite;
}

.success-glow {
  background: radial-gradient(circle, rgba(76, 175, 80, 0.3) 0%, transparent 70%);
}

.failed-glow {
  background: radial-gradient(circle, rgba(244, 67, 54, 0.3) 0%, transparent 70%);
}

@keyframes glowPulse {
  0%, 100% { transform: translate(-50%, -50%) scale(1); opacity: 1; }
  50% { transform: translate(-50%, -50%) scale(1.2); opacity: 0.6; }
}

.result-title {
  font-size: 40rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.result-content.success .result-title {
  color: #4CAF50;
}

.result-content.failed .result-title {
  color: #F44336;
}

.result-desc {
  font-size: 28rpx;
  color: #666;
  text-align: center;
  line-height: 1.6;
  margin-bottom: 32rpx;
  padding: 0 20rpx;
}

.verify-detail {
  width: 100%;
  background: #F8F8F8;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 32rpx;
}

.detail-row {
  display: flex;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.detail-row:last-child {
  margin-bottom: 0;
}

.detail-label {
