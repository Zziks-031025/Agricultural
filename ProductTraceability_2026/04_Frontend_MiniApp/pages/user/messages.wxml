<!-- 我的消息页面 -->
<view class="container">
  <!-- 顶部操作栏 -->
  <view class="action-bar">
    <view class="select-all" bindtap="toggleSelectAll">
      <view class="checkbox {{isAllSelected ? 'checked' : ''}}">
        <text wx:if="{{isAllSelected}}">✓</text>
      </view>
      <text class="select-text">全选</text>
    </view>
    <view class="action-btns">
      <view class="action-btn" bindtap="markSelectedAsRead">
        <text>标记已读</text>
      </view>
      <view class="action-btn delete-btn" bindtap="deleteSelected">
        <text>删除</text>
      </view>
    </view>
  </view>

  <!-- 消息类型筛选 -->
  <view class="tab-bar">
    <view class="tab-item {{currentTab === 'all' ? 'active' : ''}}" bindtap="switchTab" data-tab="all">
      <text>全部</text>
      <view class="badge" wx:if="{{unreadCount.all > 0}}">{{unreadCount.all > 99 ? '99+' : unreadCount.all}}</view>
    </view>
    <view class="tab-item {{currentTab === 'system' ? 'active' : ''}}" bindtap="switchTab" data-tab="system">
      <text>系统通知</text>
      <view class="badge" wx:if="{{unreadCount.system > 0}}">{{unreadCount.system > 99 ? '99+' : unreadCount.system}}</view>
    </view>
    <view class="tab-item {{currentTab === 'business' ? 'active' : ''}}" bindtap="switchTab" data-tab="business">
      <text>业务提醒</text>
      <view class="badge" wx:if="{{unreadCount.business > 0}}">{{unreadCount.business > 99 ? '99+' : unreadCount.business}}</view>
    </view>
  </view>

  <!-- 消息列表 -->
  <scroll-view class="message-list" scroll-y="true" bindscrolltolower="loadMore">
    <view class="message-item {{item.isRead ? 'read' : 'unread'}}" 
          wx:for="{{messageList}}" 
          wx:key="id"
          bindtap="viewDetail"
          data-item="{{item}}">
      <!-- 选择框 -->
      <view class="item-checkbox" catchtap="toggleSelect" data-id="{{item.id}}">
        <view class="checkbox {{item.selected ? 'checked' : ''}}">
          <text wx:if="{{item.selected}}">✓</text>
        </view>
      </view>
      
      <!-- 消息图标 -->
      <view class="message-icon {{item.type === 'system' ? 'icon-system' : 'icon-business'}}">
        <image wx:if="{{item.type === 'system'}}" class="icon-img" src="/images/Systemnotification.png" mode="aspectFit"></image>
        <image wx:else class="icon-img" src="/images/Businessnotification.png" mode="aspectFit"></image>
      </view>
      
      <!-- 消息内容 -->
      <view class="message-content">
        <view class="message-header">
          <text class="message-title">{{item.title}}</text>
          <view class="unread-dot" wx:if="{{!item.isRead}}"></view>
        </view>
        <text class="message-summary">{{item.summary}}</text>
        <view class="message-footer">
          <text class="message-type-tag {{item.type}}">{{item.type === 'system' ? '系统' : '业务'}}</text>
          <text class="message-time">{{item.timeText}}</text>
        </view>
      </view>
      
      <!-- 箭头 -->
      <view class="message-arrow">›</view>
    </view>

    <!-- 加载状态 -->
    <view class="loading-more" wx:if="{{loading}}">
      <text>加载中...</text>
    </view>
    
    <!-- 无更多数据 -->
    <view class="no-more" wx:if="{{noMore && messageList.length > 0}}">
      <text>— 没有更多消息了 —</text>
    </view>

    <!-- 空状态 -->
    <view class="empty-state" wx:if="{{!loading && messageList.length === 0}}">
      <text class="empty-text">暂无消息</text>
      <text class="empty-hint">系统通知和业务提醒会显示在这里</text>
    </view>
  </scroll-view>
</view>
