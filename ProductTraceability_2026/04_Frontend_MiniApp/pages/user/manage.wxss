.manage-container {
  min-height: 100vh;
  background: #F1F8E9;
  padding-bottom: 20rpx;
}

.page-header {
  background: #4CAF50;
  padding: 50rpx 30rpx 40rpx;
}

.header-title {
  font-size: 40rpx;
  font-weight: bold;
  color: #FFFFFF;
  margin-bottom: 10rpx;
}

.header-subtitle {
  font-size: 32rpx;
  font-weight: bold;
  color: rgba(255, 255, 255, 0.95);
  text-align: center;
}

.user-list {
  padding: 20rpx 30rpx;
}

.user-item {
  background: #FFFFFF;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.user-main {
  display: flex;
  padding: 30rpx;
}

.user-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: 50rpx;
  margin-right: 24rpx;
  flex-shrink: 0;
  border: 2rpx solid #E0E0E0;
}

.user-info {
  flex: 1;
  min-width: 0;
}

.user-name-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 12rpx;
}

.user-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
  margin-right: 20rpx;
}

.user-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  flex-shrink: 0;
}

.status-1 {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-0 {
  background: #FFEBEE;
  color: #F44336;
}

.user-detail {
  margin-bottom: 12rpx;
}

.detail-item {
  font-size: 26rpx;
  color: #666;
}

.user-role {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
}

.role-badge {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
  color: #FFFFFF;
}

.role-1 {
  background: linear-gradient(135deg, #FF9800, #F57C00);
}

.role-2 {
  background: linear-gradient(135deg, #4CAF50, #388E3C);
}

.role-3 {
  background: linear-gradient(135deg, #2196F3, #1976D2);
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-icon {
  width: 200rpx;
  height: 200rpx;
  margin-bottom: 30rpx;
}

.empty-text {
  font-size: 28rpx;
  color: #999;
}

.loading-state {
  display: flex;
  justify-content: center;
  align-items: center;
  padding: 120rpx 0;
}

.loading-text {
  font-size: 28rpx;
  color: #999;
}

.action-sheet {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 1000;
}

.sheet-mask {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
}

.sheet-content {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  background: #FFFFFF;
  border-radius: 24rpx 24rpx 0 0;
  animation: slideUp 0.3s ease-out;
}

@keyframes slideUp {
  from {
    transform: translateY(100%);
  }
  to {
    transform: translateY(0);
  }
}

.sheet-header {
  padding: 40rpx 30rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.sheet-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

.sheet-subtitle {
  font-size: 26rpx;
  color: #999;
}

.sheet-actions {
  padding: 20rpx 0;
}

.action-item {
  padding: 32rpx 30rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.action-item:last-child {
  border-bottom: none;
}

.action-text {
  font-size: 30rpx;
  color: #333;
  text-align: center;
  display: block;
}

.action-cancel .action-text {
  color: #999;
}
