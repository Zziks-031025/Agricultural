/* 消息详情页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  padding: 24rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* 消息头部 */
.message-header {
  display: flex;
  align-items: flex-start;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.header-icon {
  width: 100rpx;
  height: 100rpx;
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.header-icon .icon-img {
  width: 80rpx;
  height: 80rpx;
}

.icon-system {
  background: transparent;
}

.icon-business {
  background: transparent;
}

.header-info {
  flex: 1;
  min-width: 0;
}

.message-title {
  display: block;
  font-size: 34rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 16rpx;
  line-height: 1.4;
}

.message-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.type-tag {
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
}

.type-tag.system {
  background: #E8F5E9;
  color: #4CAF50;
}

.type-tag.business {
  background: #FFF3E0;
  color: #FF9800;
}

.message-time {
  font-size: 24rpx;
  color: #999;
}

/* 消息内容 */
.message-body {
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.message-content {
  font-size: 30rpx;
  color: #333;
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}

/* 相关操作 */
.action-section {
  margin-bottom: 24rpx;
}

.action-card {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 16rpx;
  padding: 28rpx 32rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border-left: 6rpx solid #4CAF50;
}

.action-info {
  flex: 1;
}

.action-title {
  display: block;
  font-size: 30rpx;
  font-weight: 500;
  color: #4CAF50;
  margin-bottom: 8rpx;
}

.action-desc {
  display: block;
  font-size: 26rpx;
  color: #999;
}

.action-arrow {
  font-size: 48rpx;
  color: #4CAF50;
  margin-left: 16rpx;
}

/* 底部按钮 */
.footer-btns {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  gap: 24rpx;
  padding: 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
}

.footer-btn {
  flex: 1;
  height: 88rpx;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-btn text {
  font-size: 30rpx;
  font-weight: 500;
}

.delete-btn {
  background: #FFFFFF;
  border: 2rpx solid #F44336;
}

.delete-btn text {
  color: #F44336;
}

.back-btn {
  background: #4CAF50;
}

.back-btn text {
  color: #FFFFFF;
}
