.profile-container {
  min-height: 100vh;
  background: #F5F5F5;
  padding-bottom: calc(40rpx + constant(safe-area-inset-bottom));
  padding-bottom: calc(40rpx + env(safe-area-inset-bottom));
}

/* 头像区域 */
.avatar-section {
  background: #4CAF50;
  padding: 60rpx 30rpx 50rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.avatar-wrapper {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.avatar {
  width: 180rpx;
  height: 180rpx;
  border-radius: 90rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.4);
  box-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.2);
}

.avatar-edit-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 56rpx;
  height: 56rpx;
  background: #fff;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.15);
}

.edit-icon {
  width: 32rpx;
  height: 32rpx;
}

.avatar-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

/* 表单区域 */
.form-section {
  background: #fff;
  margin: 20rpx;
  border-radius: 16rpx;
  overflow: hidden;
}

.section-title {
  padding: 24rpx;
  font-size: 26rpx;
  font-weight: 600;
  color: #4CAF50;
  background: #F8FFF8;
  border-bottom: 1rpx solid #E8F5E9;
}

.form-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #F5F5F5;
}

.form-item:last-child {
  border-bottom: none;
}

.form-label {
  width: 160rpx;
  font-size: 28rpx;
  color: #666;
  flex-shrink: 0;
}

.form-value {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  font-size: 28rpx;
  color: #333;
  min-width: 0;
}

.form-value.disabled {
  color: #999;
}

.form-value text {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.lock-icon {
  margin-left: 12rpx;
  font-size: 24rpx;
}

.arrow {
  margin-left: 12rpx;
  font-size: 40rpx;
  color: #CCC;
}

.hint-text {
  font-size: 24rpx;
  color: #999;
}

/* 角色标签 */
.role-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.role-admin {
  background: #FFEBEE;
  color: #F44336;
}

.role-enterprise {
  background: #E3F2FD;
  color: #2196F3;
}

.role-consumer {
  background: #E8F5E9;
  color: #4CAF50;
}

/* 状态标签 */
.status-tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 6rpx;
  font-size: 24rpx;
}

.status-0 {
  background: #FFF3E0;
  color: #FF9800;
}

.status-1 {
  background: #E8F5E9;
  color: #4CAF50;
}

.status-2 {
  background: #FFEBEE;
  color: #F44336;
}

/* 操作区域 */
.action-section {
  padding: 40rpx 30rpx;
}

.save-btn {
  background: linear-gradient(135deg, #4CAF50 0%, #66BB6A 100%);
  color: #fff;
  font-size: 32rpx;
  font-weight: 500;
  padding: 28rpx 0;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(76, 175, 80, 0.3);
}

.save-btn[disabled] {
  background: #E0E0E0;
  color: #999;
  box-shadow: none;
}

/* 弹窗样式 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
}

.modal-container {
  position: fixed;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  width: 600rpx;
  background: #fff;
  border-radius: 24rpx;
  overflow: hidden;
  z-index: 1000;
}

.password-modal {
  width: 650rpx;
}

.modal-header {
  padding: 36rpx 30rpx 24rpx;
  text-align: center;
  border-bottom: 1rpx solid #F0F0F0;
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.modal-body {
  padding: 30rpx;
}

.modal-input {
  width: 100%;
  height: 88rpx;
  background: #F5F5F5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.input-counter {
  text-align: right;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

.input-hint {
  margin-top: 16rpx;
}

.error-text {
  font-size: 24rpx;
  color: #F44336;
}

.password-field {
  margin-bottom: 24rpx;
  position: relative;
}

.password-field:last-of-type {
  margin-bottom: 0;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.eye-icon-wrapper {
  position: absolute;
  right: 10rpx;
  top: 50%;
  transform: translateY(-50%);
  margin-top: 18rpx;
  width: 70rpx;
  height: 70rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 10;
}

.eye-icon-img {
  width: 44rpx;
  height: 44rpx;
}

.modal-footer {
  display: flex;
  border-top: 1rpx solid #F0F0F0;
}

.modal-btn {
  flex: 1;
  padding: 28rpx 0;
  text-align: center;
  font-size: 30rpx;
}

.modal-btn.cancel {
  color: #666;
  border-right: 1rpx solid #F0F0F0;
}

.modal-btn.confirm {
  color: #4CAF50;
  font-weight: 500;
}
