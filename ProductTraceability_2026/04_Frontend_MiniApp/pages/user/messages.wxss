/* 我的消息页面样式 */
.container {
  min-height: 100vh;
  background: #F5F5F5;
  display: flex;
  flex-direction: column;
}

/* 顶部操作栏 */
.action-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  background: #FFFFFF;
  border-bottom: 1rpx solid #F0F0F0;
}

.select-all {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid #CCCCCC;
  border-radius: 6rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  font-size: 24rpx;
  color: #FFFFFF;
}

.checkbox.checked {
  background: #4CAF50;
  border-color: #4CAF50;
}

.select-text {
  font-size: 28rpx;
  color: #666;
}

.action-btns {
  display: flex;
  gap: 16rpx;
}

.action-btn {
  padding: 12rpx 24rpx;
  background: #4CAF50;
  border-radius: 8rpx;
}

.action-btn text {
  font-size: 26rpx;
  color: #FFFFFF;
}

.action-btn.delete-btn {
  background: #FFFFFF;
  border: 1rpx solid #F44336;
}

.action-btn.delete-btn text {
  color: #F44336;
}

/* 消息类型筛选 */
.tab-bar {
  display: flex;
  background: #FFFFFF;
  padding: 0 24rpx;
  border-bottom: 1rpx solid #F0F0F0;
}

.tab-item {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 0;
  position: relative;
}

.tab-item text {
  font-size: 28rpx;
  color: #666;
}

.tab-item.active text {
  color: #4CAF50;
  font-weight: 500;
}

.tab-item.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background: #4CAF50;
  border-radius: 2rpx;
}

.badge {
  position: absolute;
  top: 12rpx;
  right: 20rpx;
  min-width: 32rpx;
  height: 32rpx;
  padding: 0 8rpx;
  background: #F44336;
  border-radius: 16rpx;
  font-size: 20rpx;
  color: #FFFFFF;
  display: flex;
  align-items: center;
  justify-content: center;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 16rpx 24rpx;
}

.message-item {
  display: flex;
  align-items: center;
  background: #FFFFFF;
  border-radius: 12rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.message-item.unread {
  background: #FFFFFF;
}

.message-item.read {
  background: #FAFAFA;
}

.item-checkbox {
  margin-right: 16rpx;
}

/* 消息图标 */
.message-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.message-icon .icon-img {
  width: 60rpx;
  height: 60rpx;
}

.icon-system {
  background: transparent;
}

.icon-business {
  background: transparent;
}

/* 消息内容 */
.message-content {
  flex: 1;
  min-width: 0;
}

.message-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.message-title {
  font-size: 30rpx;
  font-weight: 500;
  color: #333;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  flex: 1;
}

.message-item.read .message-title {
  color: #666;
  font-weight: normal;
}

.unread-dot {
  width: 16rpx;
  height: 16rpx;
  background: #F44336;
  border-radius: 50%;
  margin-left: 12rpx;
  flex-shrink: 0;
}

.message-summary {
  font-size: 26rpx;
  color: #999;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
  margin-bottom: 12rpx;
}

.message-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.message-type-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 4rpx;
}

.message-type-tag.system {
  background: #E8F5E9;
  color: #4CAF50;
}

.message-type-tag.business {
  background: #FFF3E0;
  color: #FF9800;
}

.message-time {
  font-size: 24rpx;
  color: #BBBBBB;
}

.message-arrow {
  font-size: 40rpx;
  color: #CCCCCC;
  margin-left: 12rpx;
}

/* 加载状态 */
.loading-more,
.no-more {
  text-align: center;
  padding: 24rpx;
}

.loading-more text,
.no-more text {
  font-size: 24rpx;
  color: #999;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-icon {
  font-size: 120rpx;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #666;
  margin-bottom: 12rpx;
}

.empty-hint {
  font-size: 26rpx;
  color: #999;
}
